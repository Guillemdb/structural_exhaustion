{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/structural-exhaustion/concrete/runs/CT13.run.schema.json",
  "title": "CT13-v1 legal semantic-machine run",
  "description": "A legal path begins at CT13.entry, follows typed edges, and ends at one exact terminal.",
  "allOf": [
    {
      "$ref": "../../structural-exhaustion.bundle.schema.json#/$defs/tacticRun"
    },
    {
      "properties": {
        "tacticId": {
          "description": "Required CT13 run discriminator.",
          "const": "CT13"
        },
        "visitedNodeIds": {
          "description": "Execution path using only CT13-v1 semantic IDs.",
          "type": "array",
          "items": {
            "enum": [
              "CT13.entry",
              "CT13.decide.scope",
              "CT13.terminal.scope",
              "CT13.decide.availability",
              "CT13.certify.tierOne",
              "CT13.certify.tierOneRouting",
              "CT13.terminal.ct4",
              "CT13.certify.fallback",
              "CT13.decide.reconciliation",
              "CT13.certify.comparison",
              "CT13.terminal.c4",
              "CT13.decide.overlapRouting",
              "CT13.terminal.ct9",
              "CT13.terminal.ct14"
            ]
          },
          "minItems": 2
        },
        "nodeRecords": {
          "description": "Proof records aligned with the visited path.",
          "type": "array",
          "items": {
            "oneOf": [
              {
                "$ref": "../nodes/CT13.entry.schema.json"
              },
              {
                "$ref": "../nodes/CT13.decide.scope.schema.json"
              },
              {
                "$ref": "../nodes/CT13.terminal.scope.schema.json"
              },
              {
                "$ref": "../nodes/CT13.decide.availability.schema.json"
              },
              {
                "$ref": "../nodes/CT13.certify.tierOne.schema.json"
              },
              {
                "$ref": "../nodes/CT13.certify.tierOneRouting.schema.json"
              },
              {
                "$ref": "../nodes/CT13.terminal.ct4.schema.json"
              },
              {
                "$ref": "../nodes/CT13.certify.fallback.schema.json"
              },
              {
                "$ref": "../nodes/CT13.decide.reconciliation.schema.json"
              },
              {
                "$ref": "../nodes/CT13.certify.comparison.schema.json"
              },
              {
                "$ref": "../nodes/CT13.terminal.c4.schema.json"
              },
              {
                "$ref": "../nodes/CT13.decide.overlapRouting.schema.json"
              },
              {
                "$ref": "../nodes/CT13.terminal.ct9.schema.json"
              },
              {
                "$ref": "../nodes/CT13.terminal.ct14.schema.json"
              }
            ]
          },
          "minItems": 2
        },
        "outcome": {
          "description": "Exact terminal result of the CT13-v1 run.",
          "properties": {
            "terminalCase": {
              "description": "Exact terminal-case discriminator.",
              "enum": [
                "scope",
                "ct4",
                "c4",
                "ct9",
                "ct14"
              ]
            }
          },
          "required": [
            "terminalCase"
          ]
        }
      },
      "required": [
        "tacticId",
        "visitedNodeIds",
        "nodeRecords",
        "outcome"
      ]
    }
  ],
  "x-semanticValidationRules": [
    "validate visitedNodeIds against the semantic transition graph",
    "require the final node and outcome terminalCase to agree"
  ]
}
