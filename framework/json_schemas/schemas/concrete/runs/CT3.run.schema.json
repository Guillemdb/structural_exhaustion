{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/structural-exhaustion/concrete/runs/CT3.run.schema.json",
  "title": "CT3-v1 legal semantic-machine run",
  "description": "A legal path begins at CT3.entry, follows typed edges, and ends at one exact terminal.",
  "allOf": [
    {
      "$ref": "../../structural-exhaustion.bundle.schema.json#/$defs/tacticRun"
    },
    {
      "properties": {
        "tacticId": {
          "description": "Required CT3 run discriminator.",
          "const": "CT3"
        },
        "visitedNodeIds": {
          "description": "Execution path using only CT3-v1 semantic IDs.",
          "type": "array",
          "items": {
            "enum": [
              "CT3.entry",
              "CT3.decide.scope",
              "CT3.terminal.scope",
              "CT3.certify.equivalence",
              "CT3.decide.compression",
              "CT3.terminal.c2",
              "CT3.decide.defect",
              "CT3.terminal.c3",
              "CT3.terminal.ct7",
              "CT3.terminal.ct12",
              "CT3.decide.table",
              "CT3.terminal.c5",
              "CT3.terminal.ct8"
            ]
          },
          "minItems": 2
        },
        "nodeRecords": {
          "description": "Proof records aligned with the visited path.",
          "type": "array",
          "items": {
            "oneOf": [
              {
                "$ref": "../nodes/CT3.entry.schema.json"
              },
              {
                "$ref": "../nodes/CT3.decide.scope.schema.json"
              },
              {
                "$ref": "../nodes/CT3.terminal.scope.schema.json"
              },
              {
                "$ref": "../nodes/CT3.certify.equivalence.schema.json"
              },
              {
                "$ref": "../nodes/CT3.decide.compression.schema.json"
              },
              {
                "$ref": "../nodes/CT3.terminal.c2.schema.json"
              },
              {
                "$ref": "../nodes/CT3.decide.defect.schema.json"
              },
              {
                "$ref": "../nodes/CT3.terminal.c3.schema.json"
              },
              {
                "$ref": "../nodes/CT3.terminal.ct7.schema.json"
              },
              {
                "$ref": "../nodes/CT3.terminal.ct12.schema.json"
              },
              {
                "$ref": "../nodes/CT3.decide.table.schema.json"
              },
              {
                "$ref": "../nodes/CT3.terminal.c5.schema.json"
              },
              {
                "$ref": "../nodes/CT3.terminal.ct8.schema.json"
              }
            ]
          },
          "minItems": 2
        },
        "outcome": {
          "description": "Exact terminal result of the CT3-v1 run.",
          "properties": {
            "terminalCase": {
              "description": "Exact terminal-case discriminator.",
              "enum": [
                "scope",
                "c2",
                "c3",
                "ct7",
                "ct12",
                "c5",
                "ct8"
              ]
            }
          },
          "required": [
            "terminalCase"
          ]
        }
      },
      "required": [
        "tacticId",
        "visitedNodeIds",
        "nodeRecords",
        "outcome"
      ]
    }
  ],
  "x-semanticValidationRules": [
    "validate visitedNodeIds against the semantic transition graph",
    "require the final node and outcome terminalCase to agree"
  ]
}
