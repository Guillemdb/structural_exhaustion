{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/structural-exhaustion/concrete/runs/CT7.run.schema.json",
  "title": "CT7-v1 legal semantic-machine run",
  "description": "A legal path begins at CT7.entry, follows typed edges, and ends at one exact terminal.",
  "allOf": [
    {
      "$ref": "../../structural-exhaustion.bundle.schema.json#/$defs/tacticRun"
    },
    {
      "properties": {
        "tacticId": {
          "description": "Required CT7 run discriminator.",
          "const": "CT7"
        },
        "visitedNodeIds": {
          "description": "Execution path using only CT7-v1 semantic IDs.",
          "type": "array",
          "items": {
            "enum": [
              "CT7.entry",
              "CT7.decide.scope",
              "CT7.terminal.scope",
              "CT7.certify.context",
              "CT7.decide.realization",
              "CT7.terminal.c1",
              "CT7.decide.distinction",
              "CT7.decide.defect",
              "CT7.terminal.c3",
              "CT7.terminal.ct3",
              "CT7.terminal.ct12",
              "CT7.decide.neutral",
              "CT7.terminal.c2",
              "CT7.terminal.ct10",
              "CT7.terminal.ct16"
            ]
          },
          "minItems": 2
        },
        "nodeRecords": {
          "description": "Proof records aligned with the visited path.",
          "type": "array",
          "items": {
            "oneOf": [
              {
                "$ref": "../nodes/CT7.entry.schema.json"
              },
              {
                "$ref": "../nodes/CT7.decide.scope.schema.json"
              },
              {
                "$ref": "../nodes/CT7.terminal.scope.schema.json"
              },
              {
                "$ref": "../nodes/CT7.certify.context.schema.json"
              },
              {
                "$ref": "../nodes/CT7.decide.realization.schema.json"
              },
              {
                "$ref": "../nodes/CT7.terminal.c1.schema.json"
              },
              {
                "$ref": "../nodes/CT7.decide.distinction.schema.json"
              },
              {
                "$ref": "../nodes/CT7.decide.defect.schema.json"
              },
              {
                "$ref": "../nodes/CT7.terminal.c3.schema.json"
              },
              {
                "$ref": "../nodes/CT7.terminal.ct3.schema.json"
              },
              {
                "$ref": "../nodes/CT7.terminal.ct12.schema.json"
              },
              {
                "$ref": "../nodes/CT7.decide.neutral.schema.json"
              },
              {
                "$ref": "../nodes/CT7.terminal.c2.schema.json"
              },
              {
                "$ref": "../nodes/CT7.terminal.ct10.schema.json"
              },
              {
                "$ref": "../nodes/CT7.terminal.ct16.schema.json"
              }
            ]
          },
          "minItems": 2
        },
        "outcome": {
          "description": "Exact terminal result of the CT7-v1 run.",
          "properties": {
            "terminalCase": {
              "description": "Exact terminal-case discriminator.",
              "enum": [
                "scope",
                "c1",
                "c3",
                "ct3",
                "ct12",
                "c2",
                "ct10",
                "ct16"
              ]
            }
          },
          "required": [
            "terminalCase"
          ]
        }
      },
      "required": [
        "tacticId",
        "visitedNodeIds",
        "nodeRecords",
        "outcome"
      ]
    }
  ],
  "x-semanticValidationRules": [
    "validate visitedNodeIds against the semantic transition graph",
    "require the final node and outcome terminalCase to agree"
  ]
}
