{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/structural-exhaustion/concrete/runs/CT17.run.schema.json",
  "title": "CT17-v1 legal semantic-machine run",
  "description": "A legal path begins at CT17.entry, follows typed edges, and ends at one exact terminal.",
  "allOf": [
    {
      "$ref": "../../structural-exhaustion.bundle.schema.json#/$defs/tacticRun"
    },
    {
      "properties": {
        "tacticId": {
          "description": "Required CT17 run discriminator.",
          "const": "CT17"
        },
        "visitedNodeIds": {
          "description": "Execution path using only CT17-v1 semantic IDs.",
          "type": "array",
          "items": {
            "enum": [
              "CT17.entry",
              "CT17.decide.scope",
              "CT17.terminal.scope",
              "CT17.decide.compatibility",
              "CT17.decide.separation",
              "CT17.terminal.ct3",
              "CT17.terminal.ct10",
              "CT17.certify.block",
              "CT17.decide.scale",
              "CT17.decide.survivors",
              "CT17.terminal.c5",
              "CT17.terminal.ct8",
              "CT17.decide.arithmetic",
              "CT17.terminal.c1",
              "CT17.terminal.ct14"
            ]
          },
          "minItems": 2
        },
        "nodeRecords": {
          "description": "Proof records aligned with the visited path.",
          "type": "array",
          "items": {
            "oneOf": [
              {
                "$ref": "../nodes/CT17.entry.schema.json"
              },
              {
                "$ref": "../nodes/CT17.decide.scope.schema.json"
              },
              {
                "$ref": "../nodes/CT17.terminal.scope.schema.json"
              },
              {
                "$ref": "../nodes/CT17.decide.compatibility.schema.json"
              },
              {
                "$ref": "../nodes/CT17.decide.separation.schema.json"
              },
              {
                "$ref": "../nodes/CT17.terminal.ct3.schema.json"
              },
              {
                "$ref": "../nodes/CT17.terminal.ct10.schema.json"
              },
              {
                "$ref": "../nodes/CT17.certify.block.schema.json"
              },
              {
                "$ref": "../nodes/CT17.decide.scale.schema.json"
              },
              {
                "$ref": "../nodes/CT17.decide.survivors.schema.json"
              },
              {
                "$ref": "../nodes/CT17.terminal.c5.schema.json"
              },
              {
                "$ref": "../nodes/CT17.terminal.ct8.schema.json"
              },
              {
                "$ref": "../nodes/CT17.decide.arithmetic.schema.json"
              },
              {
                "$ref": "../nodes/CT17.terminal.c1.schema.json"
              },
              {
                "$ref": "../nodes/CT17.terminal.ct14.schema.json"
              }
            ]
          },
          "minItems": 2
        },
        "outcome": {
          "description": "Exact terminal result of the CT17-v1 run.",
          "properties": {
            "terminalCase": {
              "description": "Exact terminal-case discriminator.",
              "enum": [
                "scope",
                "ct3",
                "ct10",
                "c5",
                "ct8",
                "c1",
                "ct14"
              ]
            }
          },
          "required": [
            "terminalCase"
          ]
        }
      },
      "required": [
        "tacticId",
        "visitedNodeIds",
        "nodeRecords",
        "outcome"
      ]
    }
  ],
  "x-semanticValidationRules": [
    "validate visitedNodeIds against the semantic transition graph",
    "require the final node and outcome terminalCase to agree"
  ]
}
