{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/structural-exhaustion/concrete/runs/CT16.run.schema.json",
  "title": "CT16-v1 legal semantic-machine run",
  "description": "A legal path begins at CT16.entry, follows typed edges, and ends at one exact terminal.",
  "allOf": [
    {
      "$ref": "../../structural-exhaustion.bundle.schema.json#/$defs/tacticRun"
    },
    {
      "properties": {
        "tacticId": {
          "description": "Required CT16 run discriminator.",
          "const": "CT16"
        },
        "visitedNodeIds": {
          "description": "Execution path using only CT16-v1 semantic IDs.",
          "type": "array",
          "items": {
            "enum": [
              "CT16.entry",
              "CT16.decide.support",
              "CT16.terminal.ct3",
              "CT16.decide.scope",
              "CT16.terminal.scope",
              "CT16.certify.closedType",
              "CT16.decide.equality",
              "CT16.terminal.c2",
              "CT16.terminal.ct10"
            ]
          },
          "minItems": 2
        },
        "nodeRecords": {
          "description": "Proof records aligned with the visited path.",
          "type": "array",
          "items": {
            "oneOf": [
              {
                "$ref": "../nodes/CT16.entry.schema.json"
              },
              {
                "$ref": "../nodes/CT16.decide.support.schema.json"
              },
              {
                "$ref": "../nodes/CT16.terminal.ct3.schema.json"
              },
              {
                "$ref": "../nodes/CT16.decide.scope.schema.json"
              },
              {
                "$ref": "../nodes/CT16.terminal.scope.schema.json"
              },
              {
                "$ref": "../nodes/CT16.certify.closedType.schema.json"
              },
              {
                "$ref": "../nodes/CT16.decide.equality.schema.json"
              },
              {
                "$ref": "../nodes/CT16.terminal.c2.schema.json"
              },
              {
                "$ref": "../nodes/CT16.terminal.ct10.schema.json"
              }
            ]
          },
          "minItems": 2
        },
        "outcome": {
          "description": "Exact terminal result of the CT16-v1 run.",
          "properties": {
            "terminalCase": {
              "description": "Exact terminal-case discriminator.",
              "enum": [
                "ct3",
                "scope",
                "c2",
                "ct10"
              ]
            }
          },
          "required": [
            "terminalCase"
          ]
        }
      },
      "required": [
        "tacticId",
        "visitedNodeIds",
        "nodeRecords",
        "outcome"
      ]
    }
  ],
  "x-semanticValidationRules": [
    "validate visitedNodeIds against the semantic transition graph",
    "require the final node and outcome terminalCase to agree"
  ]
}
