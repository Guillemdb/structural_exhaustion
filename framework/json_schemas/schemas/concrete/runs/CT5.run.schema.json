{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/structural-exhaustion/concrete/runs/CT5.run.schema.json",
  "title": "CT5-v1 legal semantic-machine run",
  "description": "A legal path begins at CT5.entry, follows typed edges, and ends at one exact terminal.",
  "allOf": [
    {
      "$ref": "../../structural-exhaustion.bundle.schema.json#/$defs/tacticRun"
    },
    {
      "properties": {
        "tacticId": {
          "description": "Required CT5 run discriminator.",
          "const": "CT5"
        },
        "visitedNodeIds": {
          "description": "Execution path using only CT5-v1 semantic IDs.",
          "type": "array",
          "items": {
            "enum": [
              "CT5.entry",
              "CT5.decide.scope",
              "CT5.terminal.scope",
              "CT5.certify.locality",
              "CT5.decide.deficit",
              "CT5.terminal.ct11",
              "CT5.certify.summation",
              "CT5.decide.comparison",
              "CT5.terminal.c4",
              "CT5.terminal.ct4",
              "CT5.terminal.ct14"
            ]
          },
          "minItems": 2
        },
        "nodeRecords": {
          "description": "Proof records aligned with the visited path.",
          "type": "array",
          "items": {
            "oneOf": [
              {
                "$ref": "../nodes/CT5.entry.schema.json"
              },
              {
                "$ref": "../nodes/CT5.decide.scope.schema.json"
              },
              {
                "$ref": "../nodes/CT5.terminal.scope.schema.json"
              },
              {
                "$ref": "../nodes/CT5.certify.locality.schema.json"
              },
              {
                "$ref": "../nodes/CT5.decide.deficit.schema.json"
              },
              {
                "$ref": "../nodes/CT5.terminal.ct11.schema.json"
              },
              {
                "$ref": "../nodes/CT5.certify.summation.schema.json"
              },
              {
                "$ref": "../nodes/CT5.decide.comparison.schema.json"
              },
              {
                "$ref": "../nodes/CT5.terminal.c4.schema.json"
              },
              {
                "$ref": "../nodes/CT5.terminal.ct4.schema.json"
              },
              {
                "$ref": "../nodes/CT5.terminal.ct14.schema.json"
              }
            ]
          },
          "minItems": 2
        },
        "outcome": {
          "description": "Exact terminal result of the CT5-v1 run.",
          "properties": {
            "terminalCase": {
              "description": "Exact terminal-case discriminator.",
              "enum": [
                "scope",
                "ct11",
                "c4",
                "ct4",
                "ct14"
              ]
            }
          },
          "required": [
            "terminalCase"
          ]
        }
      },
      "required": [
        "tacticId",
        "visitedNodeIds",
        "nodeRecords",
        "outcome"
      ]
    }
  ],
  "x-semanticValidationRules": [
    "validate visitedNodeIds against the semantic transition graph",
    "require the final node and outcome terminalCase to agree"
  ]
}
