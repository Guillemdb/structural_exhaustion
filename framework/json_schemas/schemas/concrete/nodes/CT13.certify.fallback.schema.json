{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/structural-exhaustion/concrete/nodes/CT13.certify.fallback.schema.json",
  "title": "CT13.certify.fallback completed discharge record — Minimal-obstruction fallback certification",
  "description": "Concrete completed-discharge schema for semantic CT13-v1 node CT13.certify.fallback.",
  "allOf": [
    {
      "$ref": "../../structural-exhaustion.bundle.schema.json#/$defs/nodeProofRecord"
    },
    {
      "properties": {
        "tacticId": {
          "description": "Owning tactic discriminator for CT13.certify.fallback.",
          "const": "CT13"
        },
        "nodeId": {
          "description": "Stable semantic runtime identifier for Minimal-obstruction fallback certification.",
          "const": "CT13.certify.fallback"
        },
        "nodeNumber": {
          "description": "One-based presentation index for CT13.certify.fallback.",
          "const": 8
        },
        "status": {
          "description": "Required successful proof state for this executable machine node.",
          "const": "proved"
        },
        "dischargedContracts": {
          "description": "Exact contract families discharged at CT13.certify.fallback.",
          "type": "array",
          "uniqueItems": true,
          "minItems": 2,
          "maxItems": 2,
          "allOf": [
            {
              "contains": {
                "description": "Required S-Def evidence.",
                "const": "S-Def"
              }
            },
            {
              "contains": {
                "description": "Required S-Det evidence.",
                "const": "S-Det"
              }
            }
          ]
        },
        "contractInstances": {
          "description": "Typed contract instances for every family declared at CT13.certify.fallback.",
          "type": "array",
          "minItems": 2,
          "allOf": [
            {
              "contains": {
                "required": [
                  "schema"
                ],
                "properties": {
                  "schema": {
                    "description": "Required S-Def discriminator.",
                    "const": "S-Def"
                  }
                }
              }
            },
            {
              "contains": {
                "required": [
                  "schema"
                ],
                "properties": {
                  "schema": {
                    "description": "Required S-Det discriminator.",
                    "const": "S-Det"
                  }
                }
              }
            }
          ]
        }
      },
      "required": [
        "tacticId",
        "nodeId",
        "nodeNumber",
        "status",
        "dischargedContracts",
        "contractInstances"
      ]
    }
  ],
  "x-obligation": {
    "obligationId": "CT13.certify.fallback.O1",
    "modality": "prove",
    "statement": {
      "informal": "Execute the proof-carrying minimal-obstruction fallback certification contract.",
      "latex": ""
    },
    "contractSchemas": [
      "S-Def",
      "S-Det"
    ],
    "dependencies": [
      "CT13.decide.availability"
    ],
    "dischargeCriteria": "The node implementation constructs its indexed output contract without inspecting any later node."
  }
}
