{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/structural-exhaustion/concrete/nodes/CT16.decide.support.schema.json",
  "title": "CT16.decide.support completed discharge record — Proper/whole support decision",
  "description": "Concrete completed-discharge schema for semantic CT16-v1 node CT16.decide.support.",
  "allOf": [
    {
      "$ref": "../../structural-exhaustion.bundle.schema.json#/$defs/nodeProofRecord"
    },
    {
      "properties": {
        "tacticId": {
          "description": "Owning tactic discriminator for CT16.decide.support.",
          "const": "CT16"
        },
        "nodeId": {
          "description": "Stable semantic runtime identifier for Proper/whole support decision.",
          "const": "CT16.decide.support"
        },
        "nodeNumber": {
          "description": "One-based presentation index for CT16.decide.support.",
          "const": 2
        },
        "status": {
          "description": "Required successful proof state for this executable machine node.",
          "const": "proved"
        },
        "dischargedContracts": {
          "description": "Exact contract families discharged at CT16.decide.support.",
          "type": "array",
          "uniqueItems": true,
          "minItems": 2,
          "maxItems": 2,
          "allOf": [
            {
              "contains": {
                "description": "Required S-Dich evidence.",
                "const": "S-Dich"
              }
            },
            {
              "contains": {
                "description": "Required S-Rout evidence.",
                "const": "S-Rout"
              }
            }
          ]
        },
        "contractInstances": {
          "description": "Typed contract instances for every family declared at CT16.decide.support.",
          "type": "array",
          "minItems": 2,
          "allOf": [
            {
              "contains": {
                "required": [
                  "schema"
                ],
                "properties": {
                  "schema": {
                    "description": "Required S-Dich discriminator.",
                    "const": "S-Dich"
                  }
                }
              }
            },
            {
              "contains": {
                "required": [
                  "schema"
                ],
                "properties": {
                  "schema": {
                    "description": "Required S-Rout discriminator.",
                    "const": "S-Rout"
                  }
                }
              }
            }
          ]
        }
      },
      "required": [
        "tacticId",
        "nodeId",
        "nodeNumber",
        "status",
        "dischargedContracts",
        "contractInstances"
      ]
    }
  ],
  "x-obligation": {
    "obligationId": "CT16.decide.support.O1",
    "modality": "decide",
    "statement": {
