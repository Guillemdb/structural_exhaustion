{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/structural-exhaustion/concrete/nodes/CT3.terminal.c3.schema.json",
  "title": "CT3.terminal.c3 completed discharge record — C3 routed-account terminal",
  "description": "Concrete completed-discharge schema for semantic CT3-v1 node CT3.terminal.c3.",
  "allOf": [
    {
      "$ref": "../../structural-exhaustion.bundle.schema.json#/$defs/nodeProofRecord"
    },
    {
      "properties": {
        "tacticId": {
          "description": "Owning tactic discriminator for CT3.terminal.c3.",
          "const": "CT3"
        },
        "nodeId": {
          "description": "Stable semantic runtime identifier for C3 routed-account terminal.",
          "const": "CT3.terminal.c3"
        },
        "nodeNumber": {
          "description": "One-based presentation index for CT3.terminal.c3.",
          "const": 8
        },
        "status": {
          "description": "Required successful validation state for this entry or terminal node.",
          "const": "validated"
        },
        "dischargedContracts": {
          "description": "Exact contract families discharged at CT3.terminal.c3.",
          "type": "array",
          "uniqueItems": true,
          "minItems": 2,
          "maxItems": 2,
          "allOf": [
            {
              "contains": {
                "description": "Required S-Rout evidence.",
                "const": "S-Rout"
              }
            },
            {
              "contains": {
                "description": "Required A-Cert evidence.",
                "const": "A-Cert"
              }
            }
          ]
        },
        "contractInstances": {
          "description": "Typed contract instances for every family declared at CT3.terminal.c3.",
          "type": "array",
          "minItems": 2,
          "allOf": [
            {
              "contains": {
                "required": [
                  "schema"
                ],
                "properties": {
                  "schema": {
                    "description": "Required S-Rout discriminator.",
                    "const": "S-Rout"
                  }
                }
              }
            },
            {
              "contains": {
                "required": [
                  "schema"
                ],
                "properties": {
                  "schema": {
                    "description": "Required A-Cert discriminator.",
                    "const": "A-Cert"
                  }
                }
              }
            }
          ]
        }
      },
      "required": [
        "tacticId",
        "nodeId",
        "nodeNumber",
        "status",
        "dischargedContracts",
        "contractInstances"
      ]
    }
  ],
  "x-obligation": {
    "obligationId": "CT3.terminal.c3.O1",
    "modality": "validate",
    "statement": {
      "informal": "Execute the proof-carrying c3 routed-account terminal contract.",
      "latex": ""
    },
    "contractSchemas": [
      "S-Rout",
      "A-Cert"
    ],
    "dependencies": [
      "CT3.decide.defect"
    ],
    "dischargeCriteria": "The terminal index, incoming edge, raw outcome, and certified outcome agree definitionally."
  }
}
