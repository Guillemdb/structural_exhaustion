            },
            {
              "contains": {
                "description": "Required S-Comp evidence.",
                "const": "S-Comp"
              }
            }
          ]
        },
        "contractInstances": {
          "description": "Typed contract instances for every family declared at CT10.certify.labels.",
          "type": "array",
          "minItems": 2,
          "allOf": [
            {
              "contains": {
                "required": [
                  "schema"
                ],
                "properties": {
                  "schema": {
                    "description": "Required S-Def discriminator.",
                    "const": "S-Def"
                  }
                }
              }
            },
            {
              "contains": {
                "required": [
                  "schema"
                ],
                "properties": {
                  "schema": {
                    "description": "Required S-Comp discriminator.",
                    "const": "S-Comp"
                  }
