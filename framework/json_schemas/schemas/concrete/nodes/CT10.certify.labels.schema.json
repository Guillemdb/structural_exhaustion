  "title": "CT10.certify.labels completed discharge record — Label-class exhaustion certification",
  "description": "Concrete completed-discharge schema for semantic CT10-v1 node CT10.certify.labels.",
  "allOf": [
    {
      "$ref": "../../structural-exhaustion.bundle.schema.json#/$defs/nodeProofRecord"
