{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/structural-exhaustion/concrete/nodes/CT11.entry.schema.json",
  "title": "CT11.entry completed discharge record — Validated CT11 additive-deficit entry",
  "description": "Concrete completed-discharge schema for semantic CT11-v1 node CT11.entry.",
  "allOf": [
    {
      "$ref": "../../structural-exhaustion.bundle.schema.json#/$defs/nodeProofRecord"
    },
    {
      "properties": {
        "tacticId": {
          "description": "Owning tactic discriminator for CT11.entry.",
          "const": "CT11"
        },
        "nodeId": {
          "description": "Stable semantic runtime identifier for Validated CT11 additive-deficit entry.",
          "const": "CT11.entry"
        },
        "nodeNumber": {
          "description": "One-based presentation index for CT11.entry.",
          "const": 1
        },
        "status": {
          "description": "Required successful validation state for this entry or terminal node.",
          "const": "validated"
        },
        "dischargedContracts": {
          "description": "Exact contract families discharged at CT11.entry.",
          "type": "array",
          "uniqueItems": true,
          "minItems": 1,
          "maxItems": 1,
          "allOf": [
            {
              "contains": {
                "description": "Required S-Def evidence.",
                "const": "S-Def"
              }
            }
          ]
        },
        "contractInstances": {
          "description": "Typed contract instances for every family declared at CT11.entry.",
          "type": "array",
          "minItems": 1,
          "allOf": [
            {
              "contains": {
                "required": [
                  "schema"
                ],
                "properties": {
                  "schema": {
                    "description": "Required S-Def discriminator.",
                    "const": "S-Def"
                  }
                }
              }
            }
          ]
        }
      },
      "required": [
        "tacticId",
        "nodeId",
        "nodeNumber",
        "status",
        "dischargedContracts",
        "contractInstances"
      ]
    }
  ],
  "x-obligation": {
    "obligationId": "CT11.entry.O1",
    "modality": "validate",
    "statement": {
      "informal": "Execute the proof-carrying validated ct11 additive-deficit entry contract.",
      "latex": ""
    },
    "contractSchemas": [
      "S-Def"
    ],
    "dependencies": [],
    "dischargeCriteria": "The node implementation constructs its indexed output contract without inspecting any later node."
  }
}
