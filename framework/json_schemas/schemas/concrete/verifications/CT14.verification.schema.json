{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/structural-exhaustion/concrete/verifications/CT14.verification.schema.json",
  "title": "CT14-v1 structural all-node verification",
  "description": "Requires structural coverage of all 9 semantic states; it does not claim automatic witness search.",
  "allOf": [
    {
      "$ref": "../../structural-exhaustion.bundle.schema.json#/$defs/tacticVerification"
    },
    {
      "properties": {
        "tacticId": {
          "description": "Required CT14 verification discriminator.",
          "const": "CT14"
        },
        "nodeRecords": {
          "description": "Exactly one completed record for each CT14-v1 node.",
          "type": "array",
          "prefixItems": [
            {
              "$ref": "../nodes/CT14.entry.schema.json"
            },
            {
              "$ref": "../nodes/CT14.decide.scope.schema.json"
            },
            {
              "$ref": "../nodes/CT14.terminal.scope.schema.json"
            },
            {
              "$ref": "../nodes/CT14.certify.bounds.schema.json"
            },
            {
              "$ref": "../nodes/CT14.decide.multiplicity.schema.json"
            },
            {
              "$ref": "../nodes/CT14.terminal.ct9.schema.json"
            },
            {
              "$ref": "../nodes/CT14.terminal.ct10.schema.json"
            },
            {
              "$ref": "../nodes/CT14.certify.comparison.schema.json"
            },
            {
              "$ref": "../nodes/CT14.terminal.c4.schema.json"
            }
          ],
          "items": false,
          "minItems": 9,
          "maxItems": 9
        }
      },
      "required": [
        "tacticId",
        "nodeRecords"
      ]
    }
  ]
}
