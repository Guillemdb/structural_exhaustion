{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/structural-exhaustion/concrete/verifications/CT3.verification.schema.json",
  "title": "CT3-v1 structural all-node verification",
  "description": "Requires structural coverage of all 13 semantic states; it does not claim automatic witness search.",
  "allOf": [
    {
      "$ref": "../../structural-exhaustion.bundle.schema.json#/$defs/tacticVerification"
    },
    {
      "properties": {
        "tacticId": {
          "description": "Required CT3 verification discriminator.",
          "const": "CT3"
        },
        "nodeRecords": {
          "description": "Exactly one completed record for each CT3-v1 node.",
          "type": "array",
          "prefixItems": [
            {
              "$ref": "../nodes/CT3.entry.schema.json"
            },
            {
              "$ref": "../nodes/CT3.decide.scope.schema.json"
            },
            {
              "$ref": "../nodes/CT3.terminal.scope.schema.json"
            },
            {
              "$ref": "../nodes/CT3.certify.equivalence.schema.json"
            },
            {
              "$ref": "../nodes/CT3.decide.compression.schema.json"
            },
            {
              "$ref": "../nodes/CT3.terminal.c2.schema.json"
            },
            {
              "$ref": "../nodes/CT3.decide.defect.schema.json"
            },
            {
              "$ref": "../nodes/CT3.terminal.c3.schema.json"
            },
            {
              "$ref": "../nodes/CT3.terminal.ct7.schema.json"
            },
            {
              "$ref": "../nodes/CT3.terminal.ct12.schema.json"
            },
            {
              "$ref": "../nodes/CT3.decide.table.schema.json"
            },
            {
              "$ref": "../nodes/CT3.terminal.c5.schema.json"
            },
            {
              "$ref": "../nodes/CT3.terminal.ct8.schema.json"
            }
          ],
          "items": false,
          "minItems": 13,
          "maxItems": 13
        }
      },
      "required": [
        "tacticId",
        "nodeRecords"
      ]
    }
  ]
}
