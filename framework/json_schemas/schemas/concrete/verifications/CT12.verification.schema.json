{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/structural-exhaustion/concrete/verifications/CT12.verification.schema.json",
  "title": "CT12-v1 structural all-node verification",
  "description": "Requires structural coverage of all 11 semantic states; it does not claim automatic witness search.",
  "allOf": [
    {
      "$ref": "../../structural-exhaustion.bundle.schema.json#/$defs/tacticVerification"
    },
    {
      "properties": {
        "tacticId": {
          "description": "Required CT12 verification discriminator.",
          "const": "CT12"
        },
        "nodeRecords": {
          "description": "Exactly one completed record for each CT12-v1 node.",
          "type": "array",
          "prefixItems": [
            {
              "$ref": "../nodes/CT12.entry.schema.json"
            },
            {
              "$ref": "../nodes/CT12.decide.scope.schema.json"
            },
            {
              "$ref": "../nodes/CT12.terminal.scope.schema.json"
            },
            {
              "$ref": "../nodes/CT12.certify.measure.schema.json"
            },
            {
              "$ref": "../nodes/CT12.decide.saturation.schema.json"
            },
            {
              "$ref": "../nodes/CT12.terminal.c4.schema.json"
            },
            {
              "$ref": "../nodes/CT12.certify.peel.schema.json"
            },
            {
              "$ref": "../nodes/CT12.decide.restoration.schema.json"
            },
            {
              "$ref": "../nodes/CT12.terminal.ct4.schema.json"
            },
            {
              "$ref": "../nodes/CT12.terminal.ct13.schema.json"
            },
            {
              "$ref": "../nodes/CT12.certify.decrease.schema.json"
            }
          ],
          "items": false,
          "minItems": 11,
          "maxItems": 11
        }
      },
      "required": [
        "tacticId",
        "nodeRecords"
      ]
    }
  ]
}
