{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/structural-exhaustion/concrete/verifications/CT15.verification.schema.json",
  "title": "CT15-v1 structural all-node verification",
  "description": "Requires structural coverage of all 13 semantic states; it does not claim automatic witness search.",
  "allOf": [
    {
      "$ref": "../../structural-exhaustion.bundle.schema.json#/$defs/tacticVerification"
    },
    {
      "properties": {
        "tacticId": {
          "description": "Required CT15 verification discriminator.",
          "const": "CT15"
        },
        "nodeRecords": {
          "description": "Exactly one completed record for each CT15-v1 node.",
          "type": "array",
          "prefixItems": [
            {
              "$ref": "../nodes/CT15.entry.schema.json"
            },
            {
              "$ref": "../nodes/CT15.decide.scope.schema.json"
            },
            {
              "$ref": "../nodes/CT15.terminal.scope.schema.json"
            },
            {
              "$ref": "../nodes/CT15.certify.rank.schema.json"
            },
            {
              "$ref": "../nodes/CT15.decide.rankDrop.schema.json"
            },
            {
              "$ref": "../nodes/CT15.decide.dependenceRouting.schema.json"
            },
            {
              "$ref": "../nodes/CT15.terminal.ct3.schema.json"
            },
            {
              "$ref": "../nodes/CT15.terminal.ct7.schema.json"
            },
            {
              "$ref": "../nodes/CT15.terminal.ct16.schema.json"
            },
            {
              "$ref": "../nodes/CT15.certify.ledger.schema.json"
            },
            {
              "$ref": "../nodes/CT15.decide.comparison.schema.json"
            },
            {
              "$ref": "../nodes/CT15.terminal.c4.schema.json"
            },
            {
              "$ref": "../nodes/CT15.terminal.ct4.schema.json"
            }
          ],
          "items": false,
          "minItems": 13,
          "maxItems": 13
        }
      },
      "required": [
        "tacticId",
        "nodeRecords"
      ]
    }
  ]
}
