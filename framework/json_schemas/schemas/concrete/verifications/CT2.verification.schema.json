{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/structural-exhaustion/concrete/verifications/CT2.verification.schema.json",
  "title": "CT2-v2 structural all-node verification — Minimality and replacement",
  "description": "Concrete schema for structural branch coverage of CT2-v2. It requires one successful record for each of the twelve semantic states; this is all-node verification, not witness-search completeness.",
  "allOf": [
    {
      "$ref": "../../structural-exhaustion.bundle.schema.json#/$defs/tacticVerification"
    },
    {
      "properties": {
        "tacticId": {
          "description": "Required CT2 verification discriminator.",
          "const": "CT2"
        },
        "nodeRecords": {
          "description": "Exactly one completed record for each CT2-v2 semantic node in presentation order.",
          "type": "array",
          "prefixItems": [
            {
              "$ref": "../nodes/CT2.entry.schema.json"
            },
            {
              "$ref": "../nodes/CT2.decide.interface.schema.json"
            },
            {
              "$ref": "../nodes/CT2.terminal.scope.schema.json"
            },
            {
              "$ref": "../nodes/CT2.decide.deletion.schema.json"
            },
            {
              "$ref": "../nodes/CT2.terminal.c2.deletion.schema.json"
            },
            {
              "$ref": "../nodes/CT2.decide.replacementCandidate.schema.json"
            },
            {
              "$ref": "../nodes/CT2.decide.context.schema.json"
            },
            {
              "$ref": "../nodes/CT2.terminal.c2.replacement.schema.json"
            },
            {
              "$ref": "../nodes/CT2.terminal.ct3.context.schema.json"
            },
            {
              "$ref": "../nodes/CT2.decide.survivor.schema.json"
            },
            {
              "$ref": "../nodes/CT2.terminal.ct10.criticality.schema.json"
            },
            {
              "$ref": "../nodes/CT2.terminal.ct3.response.schema.json"
            }
          ],
          "items": false,
          "minItems": 12,
          "maxItems": 12
        }
      },
      "required": [
        "tacticId",
        "nodeRecords"
      ]
    }
  ]
}
