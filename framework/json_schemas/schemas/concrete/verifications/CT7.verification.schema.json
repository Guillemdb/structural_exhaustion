{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/structural-exhaustion/concrete/verifications/CT7.verification.schema.json",
  "title": "CT7-v1 structural all-node verification",
  "description": "Requires structural coverage of all 15 semantic states; it does not claim automatic witness search.",
  "allOf": [
    {
      "$ref": "../../structural-exhaustion.bundle.schema.json#/$defs/tacticVerification"
    },
    {
      "properties": {
        "tacticId": {
          "description": "Required CT7 verification discriminator.",
          "const": "CT7"
        },
        "nodeRecords": {
          "description": "Exactly one completed record for each CT7-v1 node.",
          "type": "array",
          "prefixItems": [
            {
              "$ref": "../nodes/CT7.entry.schema.json"
            },
            {
              "$ref": "../nodes/CT7.decide.scope.schema.json"
            },
            {
              "$ref": "../nodes/CT7.terminal.scope.schema.json"
            },
            {
              "$ref": "../nodes/CT7.certify.context.schema.json"
            },
            {
              "$ref": "../nodes/CT7.decide.realization.schema.json"
            },
            {
              "$ref": "../nodes/CT7.terminal.c1.schema.json"
            },
            {
              "$ref": "../nodes/CT7.decide.distinction.schema.json"
            },
            {
              "$ref": "../nodes/CT7.decide.defect.schema.json"
            },
            {
              "$ref": "../nodes/CT7.terminal.c3.schema.json"
            },
            {
              "$ref": "../nodes/CT7.terminal.ct3.schema.json"
            },
            {
              "$ref": "../nodes/CT7.terminal.ct12.schema.json"
            },
            {
              "$ref": "../nodes/CT7.decide.neutral.schema.json"
            },
            {
              "$ref": "../nodes/CT7.terminal.c2.schema.json"
            },
            {
              "$ref": "../nodes/CT7.terminal.ct10.schema.json"
            },
            {
              "$ref": "../nodes/CT7.terminal.ct16.schema.json"
            }
          ],
          "items": false,
          "minItems": 15,
          "maxItems": 15
        }
      },
      "required": [
        "tacticId",
        "nodeRecords"
      ]
    }
  ]
}
