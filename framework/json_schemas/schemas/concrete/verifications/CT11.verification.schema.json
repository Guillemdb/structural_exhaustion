{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/structural-exhaustion/concrete/verifications/CT11.verification.schema.json",
  "title": "CT11-v1 structural all-node verification",
  "description": "Requires structural coverage of all 11 semantic states; it does not claim automatic witness search.",
  "allOf": [
    {
      "$ref": "../../structural-exhaustion.bundle.schema.json#/$defs/tacticVerification"
    },
    {
      "properties": {
        "tacticId": {
          "description": "Required CT11 verification discriminator.",
          "const": "CT11"
        },
        "nodeRecords": {
          "description": "Exactly one completed record for each CT11-v1 node.",
          "type": "array",
          "prefixItems": [
            {
              "$ref": "../nodes/CT11.entry.schema.json"
            },
            {
              "$ref": "../nodes/CT11.decide.scope.schema.json"
            },
            {
              "$ref": "../nodes/CT11.terminal.scope.schema.json"
            },
            {
              "$ref": "../nodes/CT11.certify.decomposition.schema.json"
            },
            {
              "$ref": "../nodes/CT11.decide.admissibility.schema.json"
            },
            {
              "$ref": "../nodes/CT11.terminal.ct10.schema.json"
            },
            {
              "$ref": "../nodes/CT11.certify.localization.schema.json"
            },
            {
              "$ref": "../nodes/CT11.decide.routing.schema.json"
            },
            {
              "$ref": "../nodes/CT11.terminal.ct1.schema.json"
            },
            {
              "$ref": "../nodes/CT11.terminal.ct7.schema.json"
            },
            {
              "$ref": "../nodes/CT11.terminal.ct14.schema.json"
            }
          ],
          "items": false,
          "minItems": 11,
          "maxItems": 11
        }
      },
      "required": [
        "tacticId",
        "nodeRecords"
      ]
    }
  ]
}
