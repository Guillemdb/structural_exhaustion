{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/structural-exhaustion/concrete/verifications/CT1.verification.schema.json",
  "title": "CT1-v1 structural all-node verification",
  "description": "Requires structural coverage of all thirteen CT1-v1 states; it does not claim witness-search completeness.",
  "allOf": [
    {
      "$ref": "../../structural-exhaustion.bundle.schema.json#/$defs/tacticVerification"
    },
    {
      "properties": {
        "tacticId": {
          "description": "Required CT1 verification discriminator.",
          "const": "CT1"
        },
        "nodeRecords": {
          "description": "Exactly one completed record for each CT1-v1 semantic node.",
          "type": "array",
          "prefixItems": [
            {
              "$ref": "../nodes/CT1.entry.schema.json"
            },
            {
              "$ref": "../nodes/CT1.decide.scope.schema.json"
            },
            {
              "$ref": "../nodes/CT1.terminal.scope.schema.json"
            },
            {
              "$ref": "../nodes/CT1.certify.equivalence.schema.json"
            },
            {
              "$ref": "../nodes/CT1.decide.realization.schema.json"
            },
            {
              "$ref": "../nodes/CT1.terminal.c1.schema.json"
            },
            {
              "$ref": "../nodes/CT1.decide.payload.schema.json"
            },
            {
              "$ref": "../nodes/CT1.terminal.ct2.schema.json"
            },
            {
              "$ref": "../nodes/CT1.terminal.ct3.schema.json"
            },
            {
              "$ref": "../nodes/CT1.terminal.ct4.schema.json"
            },
            {
              "$ref": "../nodes/CT1.terminal.ct5.schema.json"
            },
            {
              "$ref": "../nodes/CT1.terminal.ct6.schema.json"
            },
            {
              "$ref": "../nodes/CT1.terminal.ct17.schema.json"
            }
          ],
          "items": false,
          "minItems": 13,
          "maxItems": 13
        }
      },
      "required": [
        "tacticId",
        "nodeRecords"
      ]
    }
  ]
}
