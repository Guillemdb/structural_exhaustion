{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/structural-exhaustion/concrete/verifications/CT10.verification.schema.json",
  "title": "CT10-v1 structural all-node verification",
  "description": "Requires structural coverage of all 12 semantic states; it does not claim automatic witness search.",
  "allOf": [
    {
      "$ref": "../../structural-exhaustion.bundle.schema.json#/$defs/tacticVerification"
    },
    {
      "properties": {
        "tacticId": {
          "description": "Required CT10 verification discriminator.",
          "const": "CT10"
        },
        "nodeRecords": {
          "description": "Exactly one completed record for each CT10-v1 node.",
          "type": "array",
          "prefixItems": [
            {
              "$ref": "../nodes/CT10.entry.schema.json"
            },
            {
              "$ref": "../nodes/CT10.decide.scope.schema.json"
            },
            {
              "$ref": "../nodes/CT10.terminal.scope.schema.json"
            },
            {
              "$ref": "../nodes/CT10.certify.labels.schema.json"
            },
            {
              "$ref": "../nodes/CT10.decide.classification.schema.json"
            },
            {
              "$ref": "../nodes/CT10.terminal.c5.schema.json"
            },
            {
              "$ref": "../nodes/CT10.decide.direct.schema.json"
            },
            {
              "$ref": "../nodes/CT10.terminal.ct3.schema.json"
            },
            {
              "$ref": "../nodes/CT10.terminal.ct7.schema.json"
            },
            {
              "$ref": "../nodes/CT10.certify.promotion.schema.json"
            },
            {
              "$ref": "../nodes/CT10.decide.promotedRouting.schema.json"
            },
            {
              "$ref": "../nodes/CT10.terminal.ct15.schema.json"
            }
          ],
          "items": false,
          "minItems": 12,
          "maxItems": 12
        }
      },
      "required": [
        "tacticId",
        "nodeRecords"
      ]
    }
  ]
}
