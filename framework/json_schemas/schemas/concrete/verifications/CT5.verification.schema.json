{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/structural-exhaustion/concrete/verifications/CT5.verification.schema.json",
  "title": "CT5-v1 structural all-node verification",
  "description": "Requires structural coverage of all 11 semantic states; it does not claim automatic witness search.",
  "allOf": [
    {
      "$ref": "../../structural-exhaustion.bundle.schema.json#/$defs/tacticVerification"
    },
    {
      "properties": {
        "tacticId": {
          "description": "Required CT5 verification discriminator.",
          "const": "CT5"
        },
        "nodeRecords": {
          "description": "Exactly one completed record for each CT5-v1 node.",
          "type": "array",
          "prefixItems": [
            {
              "$ref": "../nodes/CT5.entry.schema.json"
            },
            {
              "$ref": "../nodes/CT5.decide.scope.schema.json"
            },
            {
              "$ref": "../nodes/CT5.terminal.scope.schema.json"
            },
            {
              "$ref": "../nodes/CT5.certify.locality.schema.json"
            },
            {
              "$ref": "../nodes/CT5.decide.deficit.schema.json"
            },
            {
              "$ref": "../nodes/CT5.terminal.ct11.schema.json"
            },
            {
              "$ref": "../nodes/CT5.certify.summation.schema.json"
            },
            {
              "$ref": "../nodes/CT5.decide.comparison.schema.json"
            },
            {
              "$ref": "../nodes/CT5.terminal.c4.schema.json"
            },
            {
              "$ref": "../nodes/CT5.terminal.ct4.schema.json"
            },
            {
              "$ref": "../nodes/CT5.terminal.ct14.schema.json"
            }
          ],
          "items": false,
          "minItems": 11,
          "maxItems": 11
        }
      },
      "required": [
        "tacticId",
        "nodeRecords"
      ]
    }
  ]
}
