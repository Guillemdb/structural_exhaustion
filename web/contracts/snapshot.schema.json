{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hypostructure.dev/contracts/web-snapshot-2.0.0.schema.json",
  "title": "Hypostructure documentation snapshot",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "site",
    "pages",
    "modules",
    "declarations",
    "cts",
    "routes",
    "examples",
    "erdos",
    "sources",
    "search_documents",
    "trust"
  ],
  "properties": {
    "schema_version": {"const": "2.0.0"},
    "site": {"$ref": "#/$defs/site"},
    "pages": {
      "type": "object",
      "additionalProperties": {"$ref": "#/$defs/page"},
      "required": ["home", "start", "core", "graph", "pde", "examples", "erdos", "cts", "routes", "reference"]
    },
    "modules": {"type": "array", "items": {"$ref": "#/$defs/page"}},
    "declarations": {"type": "array", "items": {"$ref": "#/$defs/page"}},
    "cts": {
      "type": "array",
      "minItems": 17,
      "maxItems": 17,
      "items": {"$ref": "#/$defs/page"}
    },
    "routes": {"type": "array", "items": {"$ref": "#/$defs/page"}},
    "examples": {"type": "array", "items": {"$ref": "#/$defs/page"}},
    "erdos": {
      "type": "object",
      "required": ["id", "title", "summary", "nodes", "edges", "root_node_ids", "graph"],
      "properties": {
        "id": {"type": "string", "minLength": 1},
        "title": {"type": "string", "minLength": 1},
        "summary": {"type": "string", "minLength": 1},
        "nodes": {
          "type": "array",
          "minItems": 157,
          "maxItems": 157,
          "uniqueItems": true,
          "items": {"$ref": "#/$defs/erdosNode"}
        },
        "edges": {
          "type": "array",
          "minItems": 169,
          "maxItems": 169,
          "uniqueItems": true,
          "items": {"$ref": "#/$defs/erdosEdge"}
        },
        "root_node_ids": {"const": ["node-1"]},
        "graph": {
          "allOf": [
            {"$ref": "#/$defs/graphBlock"},
            {
              "type": "object",
              "properties": {
                "nodes": {
                  "type": "array",
                  "minItems": 157,
                  "maxItems": 157,
                  "uniqueItems": true,
                  "items": {"$ref": "#/$defs/erdosGraphNode"}
                },
                "edges": {
                  "type": "array",
                  "minItems": 169,
                  "maxItems": 169,
                  "uniqueItems": true,
                  "items": {"$ref": "#/$defs/erdosEdge"}
                }
              }
            }
          ]
        }
      },
      "additionalProperties": true
    },
    "sources": {"type": "array", "items": {"$ref": "#/$defs/source"}},
    "search_documents": {"type": "array", "items": {"$ref": "#/$defs/searchDocument"}},
    "trust": {
      "type": "object",
      "required": ["state"],
      "properties": {"state": {"enum": ["verified", "kernel_checked"]}},
      "additionalProperties": true
    }
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "internalHref": {
      "type": "string",
      "minLength": 1,
      "pattern": "^/(?!/)[A-Za-z0-9._~!$&'()*+,;=:@?%#/-]*$"
    },
    "link": {
      "type": "object",
      "required": ["label"],
      "properties": {
        "label": {"type": "string", "minLength": 1},
        "href": {
          "oneOf": [
            {"$ref": "#/$defs/internalHref"},
            {"type": "null"}
          ]
        }
      },
      "additionalProperties": false
    },
    "navigationLink": {
      "type": "object",
      "required": ["label", "href"],
      "properties": {
        "label": {"type": "string", "minLength": 1},
        "href": {"$ref": "#/$defs/internalHref"}
      },
      "additionalProperties": false
    },
    "metric": {
      "type": "object",
      "required": ["label", "value"],
      "properties": {
        "label": {"type": "string"},
        "value": {"type": ["string", "number"]},
        "detail": {"type": ["string", "null"]}
      },
      "additionalProperties": false
    },
    "verification": {
      "type": "object",
      "required": ["state", "label", "summary"],
      "properties": {
        "state": {"enum": ["verified", "unverified", "unavailable"]},
        "label": {"type": "string"},
        "summary": {"type": "string"},
        "details": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["label", "value"],
            "properties": {"label": {"type": "string"}, "value": {"type": "string"}},
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "site": {
      "type": "object",
      "required": ["name", "tagline", "navigation", "searchEnabled", "verification"],
      "properties": {
        "name": {"const": "Hypostructure"},
        "tagline": {"type": "string", "minLength": 1},
        "navigation": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/navigationLink"}
        },
        "searchEnabled": {"type": "boolean"},
        "verification": {"$ref": "#/$defs/verification"}
      },
      "additionalProperties": false
    },
    "page": {
      "type": "object",
      "required": ["id", "title", "summary", "sections"],
      "properties": {
        "id": {"type": "string", "minLength": 1},
        "title": {"type": "string", "minLength": 1},
        "summary": {"type": "string"},
        "description": {"type": ["string", "null"]},
        "eyebrow": {"type": ["string", "null"]},
        "breadcrumbs": {"type": "array", "items": {"$ref": "#/$defs/link"}},
        "metrics": {"type": "array", "items": {"$ref": "#/$defs/metric"}},
        "sections": {"type": "array", "items": {"$ref": "#/$defs/section"}},
        "verification": {"anyOf": [{"$ref": "#/$defs/verification"}, {"type": "null"}]},
        "canonicalPath": {"type": ["string", "null"], "pattern": "^/"}
      },
      "additionalProperties": true
    },
    "section": {
      "type": "object",
      "required": ["id", "blocks"],
      "properties": {
        "id": {"type": "string", "minLength": 1},
        "title": {"type": ["string", "null"]},
        "eyebrow": {"type": ["string", "null"]},
        "summary": {"type": ["string", "null"]},
        "blocks": {"type": "array", "items": {"$ref": "#/$defs/block"}}
      },
      "additionalProperties": false
    },
    "card": {
      "type": "object",
      "required": ["title", "summary"],
      "properties": {
        "title": {"type": "string"},
        "summary": {"type": "string"},
        "href": {"type": ["string", "null"]},
        "eyebrow": {"type": ["string", "null"]},
        "meta": {"type": ["string", "null"]}
      },
      "additionalProperties": false
    },
    "graphNode": {
      "type": "object",
      "required": ["id", "label", "x", "y"],
      "properties": {
        "id": {"type": "string"},
        "label": {"type": "string"},
        "x": {"type": "number"},
        "y": {"type": "number"},
        "kind": {"type": ["string", "null"]},
        "summary": {"type": ["string", "null"]},
        "href": {"type": ["string", "null"]}
      },
      "additionalProperties": false
    },
    "graphEdge": {
      "type": "object",
      "required": ["id", "source", "target"],
      "properties": {
        "id": {"type": "string"},
        "source": {"type": "string"},
        "target": {"type": "string"},
        "label": {"type": ["string", "null"]}
      },
      "additionalProperties": false
    },
    "erdosNodeId": {
      "type": "string",
      "pattern": "^node-(?:[1-9]|[1-9][0-9]|1[0-4][0-9]|15[0-7])$"
    },
    "erdosNode": {
      "allOf": [
        {"$ref": "#/$defs/page"},
        {
          "type": "object",
          "required": ["number", "incoming"],
          "properties": {
            "id": {"$ref": "#/$defs/erdosNodeId"},
            "number": {"type": "integer", "minimum": 1, "maximum": 157},
            "incoming": {
              "type": "array",
              "uniqueItems": true,
              "items": {"$ref": "#/$defs/erdosNodeId"}
            }
          }
        }
      ]
    },
    "erdosGraphNode": {
      "allOf": [
        {"$ref": "#/$defs/graphNode"},
        {
          "type": "object",
          "properties": {"id": {"$ref": "#/$defs/erdosNodeId"}}
        }
      ]
    },
    "erdosEdge": {
      "type": "object",
      "required": ["id", "source", "target", "label"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^node-(?:[1-9]|[1-9][0-9]|1[0-4][0-9]|15[0-7])-to-(?:[1-9]|[1-9][0-9]|1[0-4][0-9]|15[0-7])$"
        },
        "source": {"$ref": "#/$defs/erdosNodeId"},
        "target": {"$ref": "#/$defs/erdosNodeId"},
        "label": {"const": "direct predecessor"}
      },
      "additionalProperties": false
    },
    "graphBlock": {
      "type": "object",
      "required": ["kind", "nodes", "edges"],
      "properties": {
        "kind": {"const": "graph"},
        "title": {"type": ["string", "null"]},
        "description": {"type": ["string", "null"]},
        "nodes": {"type": "array", "items": {"$ref": "#/$defs/graphNode"}},
        "edges": {"type": "array", "items": {"$ref": "#/$defs/graphEdge"}},
        "legend": {"type": "array", "items": {"type": "object"}}
      },
      "additionalProperties": false
    },
    "block": {
      "oneOf": [
        {
          "type": "object",
          "required": ["kind", "html"],
          "properties": {"kind": {"const": "prose"}, "html": {"type": "string"}},
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["kind", "items"],
          "properties": {
            "kind": {"const": "cards"},
            "items": {"type": "array", "items": {"$ref": "#/$defs/card"}},
            "columns": {"enum": [2, 3, 4]}
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["kind", "tone", "title", "body"],
          "properties": {
            "kind": {"const": "callout"},
            "tone": {"enum": ["info", "success", "warning", "trust"]},
            "title": {"type": "string"},
            "body": {"type": "string"},
            "items": {
              "type": "array",
              "minItems": 1,
              "items": {"type": "string", "minLength": 1}
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["kind", "items"],
          "properties": {
            "kind": {"const": "steps"},
            "items": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["title", "body"],
                "properties": {
                  "title": {"type": "string"},
                  "body": {"type": "string"},
                  "href": {"type": ["string", "null"]}
                },
                "additionalProperties": false
              }
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["kind", "language", "code"],
          "properties": {
            "kind": {"const": "code"},
            "language": {"type": "string"},
            "code": {"type": "string"},
            "caption": {"type": ["string", "null"]},
            "sourceHref": {"type": ["string", "null"]}
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["kind", "latex"],
          "properties": {
            "kind": {"const": "math"},
            "latex": {"type": "string"},
            "display": {"type": "boolean"},
            "label": {"type": ["string", "null"]}
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["kind", "columns", "rows"],
          "properties": {
            "kind": {"const": "table"},
            "caption": {"type": ["string", "null"]},
            "columns": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["key", "label"],
                "properties": {"key": {"type": "string"}, "label": {"type": "string"}},
                "additionalProperties": false
              }
            },
            "rows": {"type": "array", "items": {"type": "object"}}
          },
          "additionalProperties": false
        },
        {"$ref": "#/$defs/graphBlock"},
        {
          "type": "object",
          "required": ["kind", "items"],
          "properties": {
            "kind": {"const": "links"},
            "items": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["label", "href"],
                "properties": {
                  "label": {"type": "string"},
                  "href": {"type": "string"},
                  "description": {"type": ["string", "null"]}
                },
                "additionalProperties": false
              }
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["kind", "items"],
          "properties": {
            "kind": {"const": "stats"},
            "items": {"type": "array", "items": {"$ref": "#/$defs/metric"}}
          },
          "additionalProperties": false
        }
      ]
    },
    "source": {
      "type": "object",
      "required": ["id", "path", "sha256", "module", "layer", "kind"],
      "properties": {
        "id": {"type": "string", "minLength": 1},
        "path": {"type": "string", "pattern": "^(hypostructure/Hypostructure|examples/hypostructure_(erdos_64_eg|pde))/"},
        "sha256": {"$ref": "#/$defs/sha256"},
        "module": {"type": "string", "minLength": 1},
        "layer": {"type": "string", "minLength": 1},
        "kind": {"type": "string", "minLength": 1}
      },
      "additionalProperties": false
    },
    "searchDocument": {
      "type": "object",
      "required": ["id", "title", "summary", "body", "url", "kind"],
      "properties": {
        "id": {"type": "string", "minLength": 1},
        "title": {"type": "string", "minLength": 1},
        "summary": {"type": "string"},
        "body": {"type": "string"},
        "url": {"type": "string", "pattern": "^/(?:$|[^/])"},
        "kind": {"type": "string", "minLength": 1},
        "module": {"type": "string"},
        "keywords": {"type": "array", "items": {"type": "string"}},
        "facets": {"type": "object", "additionalProperties": {"type": ["string", "number", "boolean"]}}
      },
      "additionalProperties": false
    }
  }
}
