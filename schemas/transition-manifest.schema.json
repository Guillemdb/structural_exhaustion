{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://structural-exhaustion.dev/schemas/transition-manifest.schema.json",
  "title": "Generated CT transition manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifactType", "schemaVersion", "transitionFamilies", "transitionProfiles"
  ],
  "properties": {
    "artifactType": {"const": "generatedTransitionManifest"},
    "schemaVersion": {"const": "1.0.0"},
    "transitionFamilies": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "$ref": "lean-machine-catalog.schema.json#/$defs/transitionFamily"
      }
    },
    "transitionProfiles": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "$ref": "lean-machine-catalog.schema.json#/$defs/transitionProfile"
      }
    }
  }
}
