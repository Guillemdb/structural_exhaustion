{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://structural-exhaustion.dev/schemas/lean-derived-manifest.schema.json",
  "title": "Lean-derived repository artifact manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["artifactType", "schemaVersion", "canonicalSource", "catalog", "schemaIndex", "tactics"],
  "properties": {
    "artifactType": {"const": "leanDerivedRepositoryManifest"},
    "schemaVersion": {"type": "string", "minLength": 1},
    "canonicalSource": {"const": "lean/StructuralExhaustion"},
    "catalog": {"const": "generated/lean-machines.json"},
    "schemaIndex": {"const": "schemas/generated/index.json"},
    "tactics": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["tacticId", "graphVersion", "nodeCount", "transitionCount", "terminalCount", "mermaid", "cytoscape", "manuscriptFigure", "tacticSchema", "runSchema", "verificationSchema", "nodeSchemaDirectory"],
        "properties": {
          "tacticId": {"type": "string", "pattern": "^CT[0-9]+$"},
          "graphVersion": {"type": "string", "minLength": 1},
          "nodeCount": {"type": "integer", "minimum": 1},
          "transitionCount": {"type": "integer", "minimum": 1},
          "terminalCount": {"type": "integer", "minimum": 1},
          "mermaid": {"type": "string", "minLength": 1},
          "cytoscape": {"type": "string", "minLength": 1},
          "manuscriptFigure": {"type": "string", "minLength": 1},
          "tacticSchema": {"type": "string", "pattern": "^schemas/generated/tactics/CT[0-9]+\\.schema\\.json$"},
          "runSchema": {"type": "string", "pattern": "^schemas/generated/runs/CT[0-9]+\\.run\\.schema\\.json$"},
          "verificationSchema": {"type": "string", "pattern": "^schemas/generated/verifications/CT[0-9]+\\.verification\\.schema\\.json$"},
          "nodeSchemaDirectory": {"const": "schemas/generated/nodes"}
        }
      }
    }
  }
}
