{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://structural-exhaustion.dev/schemas/example-detail.schema.json",
  "title": "Hydrated structural-exhaustion example",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifactType", "schemaVersion", "sourceOfTruth", "exampleId", "title",
    "summary", "proofStatus", "tacticIds", "workflows", "interfaceBindings",
    "manuscript", "declarations", "sources"
  ],
  "properties": {
    "artifactType": {"const": "structuralExhaustionExample"},
    "schemaVersion": {"const": "1.4.0"},
    "sourceOfTruth": {"$ref": "#/$defs/sourceOfTruth"},
    "exampleId": {"type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$"},
    "title": {"$ref": "#/$defs/nonemptyString"},
    "summary": {"$ref": "#/$defs/nonemptyString"},
    "proofStatus": {"enum": ["complete", "partial"]},
    "tacticIds": {
      "type": "array",
      "uniqueItems": true,
      "items": {"type": "string", "pattern": "^CT[0-9]+$"}
    },
    "workflows": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/workflow"}
    },
    "interfaceBindings": {
      "type": "array",
      "items": {"$ref": "#/$defs/interfaceBinding"}
    },
    "manuscript": {
      "oneOf": [
        {"type": "null"},
        {"$ref": "#/$defs/manuscript"}
      ]
    },
    "declarations": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/declaration"}
    },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/source"}
    }
  },
  "$defs": {
    "identifier": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9_.-]*$"
    },
    "nonemptyString": {"type": "string", "minLength": 1},
    "sourceOfTruth": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "rootModule", "descriptor"],
      "properties": {
        "kind": {"const": "compiledLeanEnvironment"},
        "rootModule": {"$ref": "#/$defs/nonemptyString"},
        "descriptor": {"$ref": "#/$defs/nonemptyString"}
      }
    },
    "stage": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "stageId", "title", "summary", "kind", "primaryDeclarationId",
        "evidenceDeclarationIds"
      ],
      "properties": {
        "stageId": {"$ref": "#/$defs/identifier"},
        "title": {"$ref": "#/$defs/nonemptyString"},
        "summary": {"$ref": "#/$defs/nonemptyString"},
        "kind": {
          "enum": ["problem", "tactic", "adapter", "certificate", "theorem", "fixture"]
        },
        "tacticId": {"type": "string", "pattern": "^CT[0-9]+$"},
        "primaryDeclarationId": {"$ref": "#/$defs/nonemptyString"},
        "evidenceDeclarationIds": {
          "type": "array",
          "uniqueItems": true,
          "items": {"$ref": "#/$defs/nonemptyString"}
        }
      }
    },
    "link": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "linkId", "sourceStageId", "targetStageId", "kind", "label",
        "summary", "automationDeclarationIds", "evidenceDeclarationIds"
      ],
      "properties": {
        "linkId": {"$ref": "#/$defs/identifier"},
        "sourceStageId": {"$ref": "#/$defs/identifier"},
        "targetStageId": {"$ref": "#/$defs/identifier"},
        "kind": {
          "enum": [
            "registeredRoute", "frameworkComposition", "proofData", "validation",
            "scheduleAudit", "sharedProblem"
          ]
        },
        "label": {"$ref": "#/$defs/nonemptyString"},
        "summary": {"$ref": "#/$defs/nonemptyString"},
        "routeId": {"$ref": "#/$defs/nonemptyString"},
        "automationDeclarationIds": {
          "type": "array",
          "uniqueItems": true,
          "items": {"$ref": "#/$defs/nonemptyString"}
        },
        "evidenceDeclarationIds": {
          "type": "array",
          "uniqueItems": true,
          "items": {"$ref": "#/$defs/nonemptyString"}
        }
      }
    },
    "workflow": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "workflowId", "title", "summary", "purpose", "completion", "stages", "links"
      ],
      "properties": {
        "workflowId": {"$ref": "#/$defs/identifier"},
        "title": {"$ref": "#/$defs/nonemptyString"},
        "summary": {"$ref": "#/$defs/nonemptyString"},
        "purpose": {"$ref": "#/$defs/nonemptyString"},
        "completion": {"enum": ["complete", "partial"]},
        "stages": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/stage"}
        },
        "links": {
          "type": "array",
          "items": {"$ref": "#/$defs/link"}
        }
      }
    },
    "interfaceBinding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "bindingId", "workflowId", "stageId", "tacticId", "role", "summary",
        "problemDeclarationId", "frameworkDeclarationId"
      ],
      "properties": {
        "bindingId": {"$ref": "#/$defs/identifier"},
        "workflowId": {"$ref": "#/$defs/identifier"},
        "stageId": {"$ref": "#/$defs/identifier"},
        "tacticId": {"type": "string", "pattern": "^CT[0-9]+$"},
        "role": {"$ref": "#/$defs/nonemptyString"},
        "summary": {"$ref": "#/$defs/nonemptyString"},
        "problemDeclarationId": {"$ref": "#/$defs/nonemptyString"},
        "frameworkDeclarationId": {"$ref": "#/$defs/nonemptyString"}
      }
    },
    "manuscriptInline": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "text"],
          "properties": {
            "kind": {"enum": ["text", "code"]},
            "text": {"type": "string"}
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind"],
          "properties": {
            "kind": {"enum": ["space", "softBreak", "lineBreak"]}
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "display", "tex"],
          "properties": {
            "kind": {"const": "math"},
            "display": {"type": "boolean"},
            "tex": {"type": "string"}
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "children"],
          "properties": {
            "kind": {
              "enum": [
                "emphasis", "strong", "underline", "strikeout", "smallCaps",
                "upright"
              ]
            },
            "children": {
              "type": "array",
              "items": {"$ref": "#/$defs/manuscriptInline"}
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "labels", "referenceKind", "prefix", "text"],
          "properties": {
            "kind": {"const": "reference"},
            "labels": {
              "type": "array",
              "minItems": 1,
              "uniqueItems": true,
              "items": {"$ref": "#/$defs/nonemptyString"}
            },
            "referenceKind": {"$ref": "#/$defs/nonemptyString"},
            "prefix": {"type": "string"},
            "text": {"$ref": "#/$defs/nonemptyString"}
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "keys", "text"],
          "properties": {
            "kind": {"const": "citation"},
            "keys": {
              "type": "array",
              "minItems": 1,
              "items": {"$ref": "#/$defs/nonemptyString"}
            },
            "text": {"$ref": "#/$defs/nonemptyString"}
          }
        }
      ]
    },
    "manuscriptBlock": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "inlines"],
          "properties": {
            "kind": {"const": "paragraph"},
            "inlines": {
              "type": "array",
              "items": {"$ref": "#/$defs/manuscriptInline"}
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "level", "label", "inlines"],
          "properties": {
            "kind": {"const": "heading"},
            "level": {"type": "integer", "minimum": 1, "maximum": 6},
            "label": {
              "oneOf": [{"type": "null"}, {"$ref": "#/$defs/nonemptyString"}]
            },
            "inlines": {
              "type": "array",
              "items": {"$ref": "#/$defs/manuscriptInline"}
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "environment", "label", "title", "blocks"],
          "properties": {
            "kind": {"const": "environment"},
            "environment": {"$ref": "#/$defs/nonemptyString"},
            "label": {
              "oneOf": [{"type": "null"}, {"$ref": "#/$defs/nonemptyString"}]
            },
            "title": {
              "oneOf": [
                {"type": "null"},
                {
                  "type": "array",
                  "minItems": 1,
                  "items": {"$ref": "#/$defs/manuscriptInline"}
                }
              ]
            },
            "blocks": {
              "type": "array",
              "items": {"$ref": "#/$defs/manuscriptBlock"}
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "start", "items"],
          "properties": {
            "kind": {"const": "orderedList"},
            "start": {"type": "integer", "minimum": 1},
            "items": {"$ref": "#/$defs/manuscriptListItems"}
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "items"],
          "properties": {
            "kind": {"const": "bulletList"},
            "items": {"$ref": "#/$defs/manuscriptListItems"}
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "blocks"],
          "properties": {
            "kind": {"const": "blockQuote"},
            "blocks": {
              "type": "array",
              "items": {"$ref": "#/$defs/manuscriptBlock"}
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "text"],
          "properties": {
            "kind": {"const": "codeBlock"},
            "text": {"type": "string"}
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "label", "svg", "svgSha256", "caption"],
          "properties": {
            "kind": {"const": "figure"},
            "label": {"$ref": "#/$defs/nonemptyString"},
            "svg": {"$ref": "#/$defs/nonemptyString"},
            "svgSha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
            "caption": {
              "type": "array",
              "items": {"$ref": "#/$defs/manuscriptBlock"}
            }
          }
        }
      ]
    },
    "manuscriptListItems": {
      "type": "array",
      "items": {
        "type": "array",
        "items": {"$ref": "#/$defs/manuscriptBlock"}
      }
    },
    "manuscriptFragment": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "label", "environment", "sourceLine", "includesProof",
        "contentSha256", "blocks"
      ],
      "properties": {
        "label": {"$ref": "#/$defs/nonemptyString"},
        "environment": {"$ref": "#/$defs/nonemptyString"},
        "sourceLine": {"type": "integer", "minimum": 1},
        "includesProof": {"type": "boolean"},
        "contentSha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "blocks": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/manuscriptBlock"}
        }
      }
    },
    "manuscriptReference": {
      "type": "object",
      "additionalProperties": false,
      "required": ["label", "title", "nodeIds"],
      "properties": {
        "label": {"$ref": "#/$defs/nonemptyString"},
        "title": {"$ref": "#/$defs/nonemptyString"},
        "nodeIds": {
          "type": "array",
          "uniqueItems": true,
          "items": {"type": "integer", "minimum": 1}
        }
      }
    },
    "declarationGroup": {
      "type": "object",
      "additionalProperties": false,
      "required": ["groupId", "title", "role", "explanation", "declarationIds"],
      "properties": {
        "groupId": {"$ref": "#/$defs/identifier"},
        "title": {"$ref": "#/$defs/nonemptyString"},
        "role": {
          "enum": [
            "mathematicalDefinition", "semanticTheorem", "encodingBridge",
            "tacticExecution", "executionAudit", "soundnessTotality",
            "workBound", "compositionProvenance", "frameworkInterface",
            "externalTheorem", "fixture"
          ]
        },
        "explanation": {"$ref": "#/$defs/nonemptyString"},
        "declarationIds": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"$ref": "#/$defs/nonemptyString"}
        }
      }
    },
    "proofStep": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "stepId", "title", "plainExplanation", "formalStatement", "status",
        "correspondence", "manuscriptRefs", "declarationGroups", "scopeNotes",
        "workBound"
      ],
      "properties": {
        "stepId": {"$ref": "#/$defs/identifier"},
        "stageId": {"$ref": "#/$defs/identifier"},
        "title": {"$ref": "#/$defs/nonemptyString"},
        "plainExplanation": {"$ref": "#/$defs/nonemptyString"},
        "formalStatement": {"$ref": "#/$defs/nonemptyString"},
        "status": {"enum": ["implemented", "next", "notStarted"]},
        "correspondence": {
          "enum": ["exact", "equivalentEncoding", "specialization", "composite", "support", "partial"]
        },
        "manuscriptRefs": {
          "type": "array",
          "items": {"$ref": "#/$defs/manuscriptReference"}
        },
        "declarationGroups": {
          "type": "array",
          "items": {"$ref": "#/$defs/declarationGroup"}
        },
        "scopeNotes": {"$ref": "#/$defs/nonemptyString"},
        "workBound": {"$ref": "#/$defs/nonemptyString"}
      }
    },
    "manuscript": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title", "path", "sha256", "fragments", "proofSteps", "coverage"],
      "properties": {
        "title": {"$ref": "#/$defs/nonemptyString"},
        "path": {
          "type": "string",
          "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$)).+\\.tex$"
        },
        "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "fragments": {
          "type": "array",
          "items": {"$ref": "#/$defs/manuscriptFragment"}
        },
        "proofSteps": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/proofStep"}
        },
        "coverage": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "implementedSteps", "totalSteps", "explainedDeclarations",
            "displayedDeclarations", "verifiedMathematicalObjects",
            "totalMathematicalObjects", "verifiedDiagramNodes",
            "totalDiagramNodes", "verifiedWorkflowSteps"
          ],
          "properties": {
            "implementedSteps": {"type": "integer", "minimum": 0},
            "totalSteps": {"type": "integer", "minimum": 1},
            "explainedDeclarations": {"type": "integer", "minimum": 0},
            "displayedDeclarations": {"type": "integer", "minimum": 0},
            "verifiedMathematicalObjects": {"type": "integer", "minimum": 0},
            "totalMathematicalObjects": {"type": "integer", "minimum": 1},
            "verifiedDiagramNodes": {"type": "integer", "minimum": 0},
            "totalDiagramNodes": {"type": "integer", "minimum": 1},
            "verifiedWorkflowSteps": {"type": "integer", "minimum": 0}
          }
        }
      }
    },
    "declaration": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "declarationId", "name", "kind", "type", "sourceId", "startLine",
        "startColumn", "endLine", "endColumn", "selectionStartLine",
        "selectionStartColumn", "selectionEndLine", "selectionEndColumn"
      ],
      "properties": {
        "declarationId": {"$ref": "#/$defs/nonemptyString"},
        "name": {"$ref": "#/$defs/nonemptyString"},
        "kind": {"$ref": "#/$defs/nonemptyString"},
        "type": {"$ref": "#/$defs/nonemptyString"},
        "sourceId": {"$ref": "#/$defs/nonemptyString"},
        "startLine": {"type": "integer", "minimum": 1},
        "startColumn": {"type": "integer", "minimum": 1},
        "endLine": {"type": "integer", "minimum": 1},
        "endColumn": {"type": "integer", "minimum": 1},
        "selectionStartLine": {"type": "integer", "minimum": 1},
        "selectionStartColumn": {"type": "integer", "minimum": 1},
        "selectionEndLine": {"type": "integer", "minimum": 1},
        "selectionEndColumn": {"type": "integer", "minimum": 1}
      }
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sourceId", "moduleName", "path", "sha256", "content"],
      "properties": {
        "sourceId": {"$ref": "#/$defs/nonemptyString"},
        "moduleName": {"$ref": "#/$defs/nonemptyString"},
        "path": {
          "type": "string",
          "minLength": 1,
          "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$)).+\\.lean$"
        },
        "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "content": {"type": "string"}
      }
    }
  }
}
