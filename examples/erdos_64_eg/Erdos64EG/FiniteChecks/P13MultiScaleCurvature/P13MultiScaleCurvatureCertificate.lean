  (rows.getD length #[]).getD source.1 0#399

/-- The manuscript's compatibility relation, packed by the reusable Core
row constructor. -/
def semanticRelation (length : Nat) (source target : Fin 399) : Bool :=
  p13FeatureSemanticRelation length source target

def semanticRow (length : Nat) (source : Fin 399) : BitVec 399 :=
  p13FeatureSemanticRow length source

def profile : Core.FiniteBitRelationBarrier.Profile 399 where
  row := row

def safeCount (leftLength rightLength : Nat) : Nat :=
  (safeCountsRows.getD leftLength #[]).getD rightLength 0

def flatCount (leftLength rightLength : Nat) : Nat :=
  (flatCountsRows.getD leftLength #[]).getD rightLength 0

set_option maxRecDepth 10000 in
theorem shape : rows.size = 15 ∧
    (∀ length : Fin 15, (rows.getD length.1 #[]).size = 399) ∧
    safeCounts.size = 225 ∧ flatCounts.size = 225 := by
  constructor
  · decide
  constructor
  · intro length
    fin_cases length <;> decide
  constructor <;> decide

