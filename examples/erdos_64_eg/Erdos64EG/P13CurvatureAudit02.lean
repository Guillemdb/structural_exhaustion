theorem p13RowsOne_codeAudit_40 : ∀ target : Fin 399,
    (p13CompatibilityRowsOne.getD 40 0#399).getLsb target =
      @decide (P13CodeCompatible 1
        (p13CurvatureCodes.getD 40 0#13)
        (p13CurvatureCodes.getD target.1 0#13))
        (p13CodeCompatibleDecidable 1 _ _) := by
  native_decide

