theorem p13RowsOne_semantic (source target : Fin 399) :
    (p13CompatibilityRowsOne.getD source.1 0#399).getLsb target = true ↔
      p13C 1 (p13CurvatureLabel source)
        (p13CurvatureLabel target) = 1 := by
  rw [p13RowsOne_codeAudit source target]
  simp only [decide_eq_true_eq, p13C_eq_one_iff, p13CurvatureLabel]
  exact p13CodeCompatible_iff 1 _ _

theorem p13RowsTwo_semantic (source target : Fin 399) :
    (p13CompatibilityRowsTwo.getD source.1 0#399).getLsb target = true ↔
      p13C 2 (p13CurvatureLabel source)
        (p13CurvatureLabel target) = 1 := by
  rw [p13RowsTwo_codeAudit source target]
  simp only [decide_eq_true_eq, p13C_eq_one_iff, p13CurvatureLabel]
  exact p13CodeCompatible_iff 2 _ _

def p13SafeWedgeCount : Nat :=
  p13CompatibilityRowsOne.foldl
    (fun total row => total + row.cpop.toNat ^ 2) 0

def p13CommonMiddleCount (source target : Fin 399) : Nat :=
  (((p13CompatibilityRowsOne.getD source.1 0#399) &&&
      (p13CompatibilityRowsOne.getD target.1 0#399)).cpop).toNat

def p13PositiveCurvatureCount : Nat :=
  (List.finRange 399).foldl (fun total source =>
    total + (List.finRange 399).foldl (fun subtotal target =>
      if !(p13CompatibilityRowsTwo.getD source.1 0#399).getLsb target then
        subtotal + p13CommonMiddleCount source target
      else subtotal) 0) 0

def p13FlatCurvatureCount : Nat :=
  p13SafeWedgeCount - p13PositiveCurvatureCount

theorem p13Curvature_count_computation :
    p13SafeWedgeCount = 543958 ∧
      p13PositiveCurvatureCount = 432672 ∧
      p13FlatCurvatureCount = 111286 := by
  native_decide

theorem p13SafeWedge_count : p13SafeWedgeCount = 543958 :=
  p13Curvature_count_computation.1

theorem p13PositiveCurvature_count :
    p13PositiveCurvatureCount = 432672 :=
  p13Curvature_count_computation.2.1

theorem p13FlatCurvature_count : p13FlatCurvatureCount = 111286 :=
  p13Curvature_count_computation.2.2

theorem p13Curvature_partition :
    p13PositiveCurvatureCount + p13FlatCurvatureCount =
      p13SafeWedgeCount := by
  rw [p13PositiveCurvature_count, p13FlatCurvature_count,
    p13SafeWedge_count]

def p13CurvatureCheckCount : Nat := 3 * 399 ^ 2

theorem p13CurvatureCheckCount_quadratic :
    p13CurvatureCheckCount ≤ 3 * p13CurvatureCodes.size ^ 2 := by
  rw [p13CurvatureCodes_size]
  simp [p13CurvatureCheckCount]

def p13CurvatureFlatnessRatio : Rat := 543958 / 111286

theorem p13CurvatureFlatnessRatio_exact :
    p13CurvatureFlatnessRatio = 271979 / 55643 := by
  norm_num [p13CurvatureFlatnessRatio]

structure VerifiedP13CurvatureEnumeration
    (ctx : Core.MinimalCounterexampleContext PackedProblem.{u} PackedTarget.{u}) where
  previous : BoundedSurplusScaleResidual ctx
  legalLabels : p13CurvatureCodes.size = 399
  rowOneSemantic : ∀ source target : Fin 399,
    (p13CompatibilityRowsOne.getD source.1 0#399).getLsb target = true ↔
      p13C 1 (p13CurvatureLabel source)
        (p13CurvatureLabel target) = 1
  rowTwoSemantic : ∀ source target : Fin 399,
    (p13CompatibilityRowsTwo.getD source.1 0#399).getLsb target = true ↔
      p13C 2 (p13CurvatureLabel source)
        (p13CurvatureLabel target) = 1
  safe : p13SafeWedgeCount = 543958
  positive : p13PositiveCurvatureCount = 432672
  flat : p13FlatCurvatureCount = 111286
  partition : p13PositiveCurvatureCount + p13FlatCurvatureCount =
    p13SafeWedgeCount
  quadraticWork : p13CurvatureCheckCount ≤
    3 * p13CurvatureCodes.size ^ 2

def verifiedP13CurvatureEnumeration
    (ctx : Core.MinimalCounterexampleContext PackedProblem.{u} PackedTarget.{u})
    (previous : BoundedSurplusScaleResidual ctx) :
    VerifiedP13CurvatureEnumeration ctx where
  previous := previous
  legalLabels := p13CurvatureCodes_size
  rowOneSemantic := p13RowsOne_semantic
  rowTwoSemantic := p13RowsTwo_semantic
  safe := p13SafeWedge_count
  positive := p13PositiveCurvature_count
  flat := p13FlatCurvature_count
  partition := p13Curvature_partition
  quadraticWork := p13CurvatureCheckCount_quadratic

end Erdos64EG.Internal

