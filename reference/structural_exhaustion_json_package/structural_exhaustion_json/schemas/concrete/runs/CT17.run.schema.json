{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/structural-exhaustion/concrete/runs/CT17.run.schema.json",
  "title": "CT17 legal branch run — Target thickening",
  "description": "Concrete schema for one legal execution branch of CT17 (Target thickening). A conforming run may use only CT17 node IDs and records, must start at an entry node, follow declared transitions with repetition only on declared loops, align every proof record with its visited node ID, and finish with a matching outcome.",
  "allOf": [
    {
      "$ref": "../../structural-exhaustion.bundle.schema.json#/$defs/tacticRun"
    },
    {
      "properties": {
        "tacticId": {
          "const": "CT17",
          "description": "Required discriminator for a branch execution of CT17 (Target thickening); must equal \"CT17\"."
        },
        "visitedNodeIds": {
          "items": {
            "enum": [
              "CT17.N01",
              "CT17.N02",
              "CT17.N03",
              "CT17.N04",
              "CT17.N05",
              "CT17.N06",
              "CT17.N07",
              "CT17.N08",
              "CT17.N09",
              "CT17.N10",
              "CT17.N11",
              "CT17.N12",
              "CT17.N13",
              "CT17.N14",
              "CT17.N15",
              "CT17.N16",
              "CT17.N17",
              "CT17.N18",
              "CT17.N19",
              "CT17.N20",
              "CT17.N21"
            ]
          },
          "description": "Required execution-order path for one actual CT17 (Target thickening) branch. Every item must be a concrete ID from CT17.N01 through CT17.N21; the first must be an entry node, adjacent IDs must follow a declared CT17 transition, and repeats are allowed only on a declared loop."
        },
        "nodeRecords": {
          "items": {
            "oneOf": [
              {
                "$ref": "../nodes/CT17.N01.schema.json"
              },
              {
                "$ref": "../nodes/CT17.N02.schema.json"
              },
              {
                "$ref": "../nodes/CT17.N03.schema.json"
              },
              {
                "$ref": "../nodes/CT17.N04.schema.json"
              },
              {
                "$ref": "../nodes/CT17.N05.schema.json"
              },
              {
                "$ref": "../nodes/CT17.N06.schema.json"
              },
              {
                "$ref": "../nodes/CT17.N07.schema.json"
              },
              {
                "$ref": "../nodes/CT17.N08.schema.json"
              },
              {
                "$ref": "../nodes/CT17.N09.schema.json"
              },
              {
                "$ref": "../nodes/CT17.N10.schema.json"
              },
              {
                "$ref": "../nodes/CT17.N11.schema.json"
              },
              {
                "$ref": "../nodes/CT17.N12.schema.json"
              },
              {
                "$ref": "../nodes/CT17.N13.schema.json"
              },
              {
                "$ref": "../nodes/CT17.N14.schema.json"
              },
              {
                "$ref": "../nodes/CT17.N15.schema.json"
              },
              {
                "$ref": "../nodes/CT17.N16.schema.json"
              },
              {
                "$ref": "../nodes/CT17.N17.schema.json"
              },
              {
                "$ref": "../nodes/CT17.N18.schema.json"
              },
              {
                "$ref": "../nodes/CT17.N19.schema.json"
              },
              {
                "$ref": "../nodes/CT17.N20.schema.json"
              },
              {
                "$ref": "../nodes/CT17.N21.schema.json"
              }
            ]
          },
          "description": "Required discharge records aligned position-for-position with visitedNodeIds for this CT17 run. The array must have the same length as visitedNodeIds; every item must match one concrete CT17 node-record schema and its nodeId must equal the corresponding visited ID."
        }
      },
      "required": [
        "tacticId",
        "visitedNodeIds",
        "nodeRecords"
      ]
    }
  ],
  "x-semanticValidationRules": [
    "validate visitedNodeIds as a path in the corresponding tactic transition graph"
  ]
}
