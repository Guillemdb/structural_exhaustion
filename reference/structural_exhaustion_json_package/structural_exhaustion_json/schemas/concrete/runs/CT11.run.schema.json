{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/structural-exhaustion/concrete/runs/CT11.run.schema.json",
  "title": "CT11 legal branch run — Localization",
  "description": "Concrete schema for one legal execution branch of CT11 (Localization). A conforming run may use only CT11 node IDs and records, must start at an entry node, follow declared transitions with repetition only on declared loops, align every proof record with its visited node ID, and finish with a matching outcome.",
  "allOf": [
    {
      "$ref": "../../structural-exhaustion.bundle.schema.json#/$defs/tacticRun"
    },
    {
      "properties": {
        "tacticId": {
          "const": "CT11",
          "description": "Required discriminator for a branch execution of CT11 (Localization); must equal \"CT11\"."
        },
        "visitedNodeIds": {
          "items": {
            "enum": [
              "CT11.N01",
              "CT11.N02",
              "CT11.N03",
              "CT11.N04",
              "CT11.N05",
              "CT11.N06",
              "CT11.N07",
              "CT11.N08",
              "CT11.N09",
              "CT11.N10",
              "CT11.N11",
              "CT11.N12",
              "CT11.N13",
              "CT11.N14",
              "CT11.N15",
              "CT11.N16",
              "CT11.N17",
              "CT11.N18",
              "CT11.N19"
            ]
          },
          "description": "Required execution-order path for one actual CT11 (Localization) branch. Every item must be a concrete ID from CT11.N01 through CT11.N19; the first must be an entry node, adjacent IDs must follow a declared CT11 transition, and repeats are allowed only on a declared loop."
        },
        "nodeRecords": {
          "items": {
            "oneOf": [
              {
                "$ref": "../nodes/CT11.N01.schema.json"
              },
              {
                "$ref": "../nodes/CT11.N02.schema.json"
              },
              {
                "$ref": "../nodes/CT11.N03.schema.json"
              },
              {
                "$ref": "../nodes/CT11.N04.schema.json"
              },
              {
                "$ref": "../nodes/CT11.N05.schema.json"
              },
              {
                "$ref": "../nodes/CT11.N06.schema.json"
              },
              {
                "$ref": "../nodes/CT11.N07.schema.json"
              },
              {
                "$ref": "../nodes/CT11.N08.schema.json"
              },
              {
                "$ref": "../nodes/CT11.N09.schema.json"
              },
              {
                "$ref": "../nodes/CT11.N10.schema.json"
              },
              {
                "$ref": "../nodes/CT11.N11.schema.json"
              },
              {
                "$ref": "../nodes/CT11.N12.schema.json"
              },
              {
                "$ref": "../nodes/CT11.N13.schema.json"
              },
              {
                "$ref": "../nodes/CT11.N14.schema.json"
              },
              {
                "$ref": "../nodes/CT11.N15.schema.json"
              },
              {
                "$ref": "../nodes/CT11.N16.schema.json"
              },
              {
                "$ref": "../nodes/CT11.N17.schema.json"
              },
              {
                "$ref": "../nodes/CT11.N18.schema.json"
              },
              {
                "$ref": "../nodes/CT11.N19.schema.json"
              }
            ]
          },
          "description": "Required discharge records aligned position-for-position with visitedNodeIds for this CT11 run. The array must have the same length as visitedNodeIds; every item must match one concrete CT11 node-record schema and its nodeId must equal the corresponding visited ID."
        }
      },
      "required": [
        "tacticId",
        "visitedNodeIds",
        "nodeRecords"
      ]
    }
  ],
  "x-semanticValidationRules": [
    "validate visitedNodeIds as a path in the corresponding tactic transition graph"
  ]
}
