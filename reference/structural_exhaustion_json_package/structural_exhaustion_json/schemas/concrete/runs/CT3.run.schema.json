{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/structural-exhaustion/concrete/runs/CT3.run.schema.json",
  "title": "CT3 legal branch run — External-type compression",
  "description": "Concrete schema for one legal execution branch of CT3 (External-type compression). A conforming run may use only CT3 node IDs and records, must start at an entry node, follow declared transitions with repetition only on declared loops, align every proof record with its visited node ID, and finish with a matching outcome.",
  "allOf": [
    {
      "$ref": "../../structural-exhaustion.bundle.schema.json#/$defs/tacticRun"
    },
    {
      "properties": {
        "tacticId": {
          "const": "CT3",
          "description": "Required discriminator for a branch execution of CT3 (External-type compression); must equal \"CT3\"."
        },
        "visitedNodeIds": {
          "items": {
            "enum": [
              "CT3.N01",
              "CT3.N02",
              "CT3.N03",
              "CT3.N04",
              "CT3.N05",
              "CT3.N06",
              "CT3.N07",
              "CT3.N08",
              "CT3.N09",
              "CT3.N10",
              "CT3.N11",
              "CT3.N12",
              "CT3.N13",
              "CT3.N14",
              "CT3.N15",
              "CT3.N16",
              "CT3.N17",
              "CT3.N18",
              "CT3.N19",
              "CT3.N20"
            ]
          },
          "description": "Required execution-order path for one actual CT3 (External-type compression) branch. Every item must be a concrete ID from CT3.N01 through CT3.N20; the first must be an entry node, adjacent IDs must follow a declared CT3 transition, and repeats are allowed only on a declared loop."
        },
        "nodeRecords": {
          "items": {
            "oneOf": [
              {
                "$ref": "../nodes/CT3.N01.schema.json"
              },
              {
                "$ref": "../nodes/CT3.N02.schema.json"
              },
              {
                "$ref": "../nodes/CT3.N03.schema.json"
              },
              {
                "$ref": "../nodes/CT3.N04.schema.json"
              },
              {
                "$ref": "../nodes/CT3.N05.schema.json"
              },
              {
                "$ref": "../nodes/CT3.N06.schema.json"
              },
              {
                "$ref": "../nodes/CT3.N07.schema.json"
              },
              {
                "$ref": "../nodes/CT3.N08.schema.json"
              },
              {
                "$ref": "../nodes/CT3.N09.schema.json"
              },
              {
                "$ref": "../nodes/CT3.N10.schema.json"
              },
              {
                "$ref": "../nodes/CT3.N11.schema.json"
              },
              {
                "$ref": "../nodes/CT3.N12.schema.json"
              },
              {
                "$ref": "../nodes/CT3.N13.schema.json"
              },
              {
                "$ref": "../nodes/CT3.N14.schema.json"
              },
              {
                "$ref": "../nodes/CT3.N15.schema.json"
              },
              {
                "$ref": "../nodes/CT3.N16.schema.json"
              },
              {
                "$ref": "../nodes/CT3.N17.schema.json"
              },
              {
                "$ref": "../nodes/CT3.N18.schema.json"
              },
              {
                "$ref": "../nodes/CT3.N19.schema.json"
              },
              {
                "$ref": "../nodes/CT3.N20.schema.json"
              }
            ]
          },
          "description": "Required discharge records aligned position-for-position with visitedNodeIds for this CT3 run. The array must have the same length as visitedNodeIds; every item must match one concrete CT3 node-record schema and its nodeId must equal the corresponding visited ID."
        }
      },
      "required": [
        "tacticId",
        "visitedNodeIds",
        "nodeRecords"
      ]
    }
  ],
  "x-semanticValidationRules": [
    "validate visitedNodeIds as a path in the corresponding tactic transition graph"
  ]
}
