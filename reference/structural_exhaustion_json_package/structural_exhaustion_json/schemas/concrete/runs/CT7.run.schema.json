{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/structural-exhaustion/concrete/runs/CT7.run.schema.json",
  "title": "CT7 legal branch run — Exchange trichotomy",
  "description": "Concrete schema for one legal execution branch of CT7 (Exchange trichotomy). A conforming run may use only CT7 node IDs and records, must start at an entry node, follow declared transitions with repetition only on declared loops, align every proof record with its visited node ID, and finish with a matching outcome.",
  "allOf": [
    {
      "$ref": "../../structural-exhaustion.bundle.schema.json#/$defs/tacticRun"
    },
    {
      "properties": {
        "tacticId": {
          "const": "CT7",
          "description": "Required discriminator for a branch execution of CT7 (Exchange trichotomy); must equal \"CT7\"."
        },
        "visitedNodeIds": {
          "items": {
            "enum": [
              "CT7.N01",
              "CT7.N02",
              "CT7.N03",
              "CT7.N04",
              "CT7.N05",
              "CT7.N06",
              "CT7.N07",
              "CT7.N08",
              "CT7.N09",
              "CT7.N10",
              "CT7.N11",
              "CT7.N12",
              "CT7.N13",
              "CT7.N14",
              "CT7.N15",
              "CT7.N16",
              "CT7.N17",
              "CT7.N18",
              "CT7.N19",
              "CT7.N20"
            ]
          },
          "description": "Required execution-order path for one actual CT7 (Exchange trichotomy) branch. Every item must be a concrete ID from CT7.N01 through CT7.N20; the first must be an entry node, adjacent IDs must follow a declared CT7 transition, and repeats are allowed only on a declared loop."
        },
        "nodeRecords": {
          "items": {
            "oneOf": [
              {
                "$ref": "../nodes/CT7.N01.schema.json"
              },
              {
                "$ref": "../nodes/CT7.N02.schema.json"
              },
              {
                "$ref": "../nodes/CT7.N03.schema.json"
              },
              {
                "$ref": "../nodes/CT7.N04.schema.json"
              },
              {
                "$ref": "../nodes/CT7.N05.schema.json"
              },
              {
                "$ref": "../nodes/CT7.N06.schema.json"
              },
              {
                "$ref": "../nodes/CT7.N07.schema.json"
              },
              {
                "$ref": "../nodes/CT7.N08.schema.json"
              },
              {
                "$ref": "../nodes/CT7.N09.schema.json"
              },
              {
                "$ref": "../nodes/CT7.N10.schema.json"
              },
              {
                "$ref": "../nodes/CT7.N11.schema.json"
              },
              {
                "$ref": "../nodes/CT7.N12.schema.json"
              },
              {
                "$ref": "../nodes/CT7.N13.schema.json"
              },
              {
                "$ref": "../nodes/CT7.N14.schema.json"
              },
              {
                "$ref": "../nodes/CT7.N15.schema.json"
              },
              {
                "$ref": "../nodes/CT7.N16.schema.json"
              },
              {
                "$ref": "../nodes/CT7.N17.schema.json"
              },
              {
                "$ref": "../nodes/CT7.N18.schema.json"
              },
              {
                "$ref": "../nodes/CT7.N19.schema.json"
              },
              {
                "$ref": "../nodes/CT7.N20.schema.json"
              }
            ]
          },
          "description": "Required discharge records aligned position-for-position with visitedNodeIds for this CT7 run. The array must have the same length as visitedNodeIds; every item must match one concrete CT7 node-record schema and its nodeId must equal the corresponding visited ID."
        }
      },
      "required": [
        "tacticId",
        "visitedNodeIds",
        "nodeRecords"
      ]
    }
  ],
  "x-semanticValidationRules": [
    "validate visitedNodeIds as a path in the corresponding tactic transition graph"
  ]
}
