{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/structural-exhaustion/concrete/runs/CT15.run.schema.json",
  "title": "CT15 legal branch run — Rank forcing",
  "description": "Concrete schema for one legal execution branch of CT15 (Rank forcing). A conforming run may use only CT15 node IDs and records, must start at an entry node, follow declared transitions with repetition only on declared loops, align every proof record with its visited node ID, and finish with a matching outcome.",
  "allOf": [
    {
      "$ref": "../../structural-exhaustion.bundle.schema.json#/$defs/tacticRun"
    },
    {
      "properties": {
        "tacticId": {
          "const": "CT15",
          "description": "Required discriminator for a branch execution of CT15 (Rank forcing); must equal \"CT15\"."
        },
        "visitedNodeIds": {
          "items": {
            "enum": [
              "CT15.N01",
              "CT15.N02",
              "CT15.N03",
              "CT15.N04",
              "CT15.N05",
              "CT15.N06",
              "CT15.N07",
              "CT15.N08",
              "CT15.N09",
              "CT15.N10",
              "CT15.N11",
              "CT15.N12",
              "CT15.N13",
              "CT15.N14",
              "CT15.N15",
              "CT15.N16",
              "CT15.N17",
              "CT15.N18",
              "CT15.N19",
              "CT15.N20",
              "CT15.N21"
            ]
          },
          "description": "Required execution-order path for one actual CT15 (Rank forcing) branch. Every item must be a concrete ID from CT15.N01 through CT15.N21; the first must be an entry node, adjacent IDs must follow a declared CT15 transition, and repeats are allowed only on a declared loop."
        },
        "nodeRecords": {
          "items": {
            "oneOf": [
              {
                "$ref": "../nodes/CT15.N01.schema.json"
              },
              {
                "$ref": "../nodes/CT15.N02.schema.json"
              },
              {
                "$ref": "../nodes/CT15.N03.schema.json"
              },
              {
                "$ref": "../nodes/CT15.N04.schema.json"
              },
              {
                "$ref": "../nodes/CT15.N05.schema.json"
              },
              {
                "$ref": "../nodes/CT15.N06.schema.json"
              },
              {
                "$ref": "../nodes/CT15.N07.schema.json"
              },
              {
                "$ref": "../nodes/CT15.N08.schema.json"
              },
              {
                "$ref": "../nodes/CT15.N09.schema.json"
              },
              {
                "$ref": "../nodes/CT15.N10.schema.json"
              },
              {
                "$ref": "../nodes/CT15.N11.schema.json"
              },
              {
                "$ref": "../nodes/CT15.N12.schema.json"
              },
              {
                "$ref": "../nodes/CT15.N13.schema.json"
              },
              {
                "$ref": "../nodes/CT15.N14.schema.json"
              },
              {
                "$ref": "../nodes/CT15.N15.schema.json"
              },
              {
                "$ref": "../nodes/CT15.N16.schema.json"
              },
              {
                "$ref": "../nodes/CT15.N17.schema.json"
              },
              {
                "$ref": "../nodes/CT15.N18.schema.json"
              },
              {
                "$ref": "../nodes/CT15.N19.schema.json"
              },
              {
                "$ref": "../nodes/CT15.N20.schema.json"
              },
              {
                "$ref": "../nodes/CT15.N21.schema.json"
              }
            ]
          },
          "description": "Required discharge records aligned position-for-position with visitedNodeIds for this CT15 run. The array must have the same length as visitedNodeIds; every item must match one concrete CT15 node-record schema and its nodeId must equal the corresponding visited ID."
        }
      },
      "required": [
        "tacticId",
        "visitedNodeIds",
        "nodeRecords"
      ]
    }
  ],
  "x-semanticValidationRules": [
    "validate visitedNodeIds as a path in the corresponding tactic transition graph"
  ]
}
