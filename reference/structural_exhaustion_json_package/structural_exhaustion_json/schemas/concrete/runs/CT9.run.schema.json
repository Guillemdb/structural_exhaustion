{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/structural-exhaustion/concrete/runs/CT9.run.schema.json",
  "title": "CT9 legal branch run — Overload exhaustion",
  "description": "Concrete schema for one legal execution branch of CT9 (Overload exhaustion). A conforming run may use only CT9 node IDs and records, must start at an entry node, follow declared transitions with repetition only on declared loops, align every proof record with its visited node ID, and finish with a matching outcome.",
  "allOf": [
    {
      "$ref": "../../structural-exhaustion.bundle.schema.json#/$defs/tacticRun"
    },
    {
      "properties": {
        "tacticId": {
          "const": "CT9",
          "description": "Required discriminator for a branch execution of CT9 (Overload exhaustion); must equal \"CT9\"."
        },
        "visitedNodeIds": {
          "items": {
            "enum": [
              "CT9.N01",
              "CT9.N02",
              "CT9.N03",
              "CT9.N04",
              "CT9.N05",
              "CT9.N06",
              "CT9.N07",
              "CT9.N08",
              "CT9.N09",
              "CT9.N10",
              "CT9.N11",
              "CT9.N12",
              "CT9.N13",
              "CT9.N14",
              "CT9.N15",
              "CT9.N16",
              "CT9.N17",
              "CT9.N18",
              "CT9.N19"
            ]
          },
          "description": "Required execution-order path for one actual CT9 (Overload exhaustion) branch. Every item must be a concrete ID from CT9.N01 through CT9.N19; the first must be an entry node, adjacent IDs must follow a declared CT9 transition, and repeats are allowed only on a declared loop."
        },
        "nodeRecords": {
          "items": {
            "oneOf": [
              {
                "$ref": "../nodes/CT9.N01.schema.json"
              },
              {
                "$ref": "../nodes/CT9.N02.schema.json"
              },
              {
                "$ref": "../nodes/CT9.N03.schema.json"
              },
              {
                "$ref": "../nodes/CT9.N04.schema.json"
              },
              {
                "$ref": "../nodes/CT9.N05.schema.json"
              },
              {
                "$ref": "../nodes/CT9.N06.schema.json"
              },
              {
                "$ref": "../nodes/CT9.N07.schema.json"
              },
              {
                "$ref": "../nodes/CT9.N08.schema.json"
              },
              {
                "$ref": "../nodes/CT9.N09.schema.json"
              },
              {
                "$ref": "../nodes/CT9.N10.schema.json"
              },
              {
                "$ref": "../nodes/CT9.N11.schema.json"
              },
              {
                "$ref": "../nodes/CT9.N12.schema.json"
              },
              {
                "$ref": "../nodes/CT9.N13.schema.json"
              },
              {
                "$ref": "../nodes/CT9.N14.schema.json"
              },
              {
                "$ref": "../nodes/CT9.N15.schema.json"
              },
              {
                "$ref": "../nodes/CT9.N16.schema.json"
              },
              {
                "$ref": "../nodes/CT9.N17.schema.json"
              },
              {
                "$ref": "../nodes/CT9.N18.schema.json"
              },
              {
                "$ref": "../nodes/CT9.N19.schema.json"
              }
            ]
          },
          "description": "Required discharge records aligned position-for-position with visitedNodeIds for this CT9 run. The array must have the same length as visitedNodeIds; every item must match one concrete CT9 node-record schema and its nodeId must equal the corresponding visited ID."
        }
      },
      "required": [
        "tacticId",
        "visitedNodeIds",
        "nodeRecords"
      ]
    }
  ],
  "x-semanticValidationRules": [
    "validate visitedNodeIds as a path in the corresponding tactic transition graph"
  ]
}
