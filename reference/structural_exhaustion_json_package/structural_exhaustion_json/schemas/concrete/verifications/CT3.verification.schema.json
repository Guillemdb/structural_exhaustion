        "tacticId": {
          "const": "CT3",
          "description": "Required discriminator for the complete verification of CT3 (External-type compression); must equal \"CT3\"."
        },
        "nodeRecords": {
          "type": "array",
          "prefixItems": [
            {
              "$ref": "../nodes/CT3.N01.schema.json"
            },
            {
              "$ref": "../nodes/CT3.N02.schema.json"
            },
            {
