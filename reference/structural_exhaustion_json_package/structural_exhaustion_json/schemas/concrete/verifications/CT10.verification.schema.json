            },
            {
              "$ref": "../nodes/CT10.N06.schema.json"
            },
            {
              "$ref": "../nodes/CT10.N07.schema.json"
            },
            {
              "$ref": "../nodes/CT10.N08.schema.json"
            },
            {
              "$ref": "../nodes/CT10.N09.schema.json"
            },
            {
              "$ref": "../nodes/CT10.N10.schema.json"
            },
            {
              "$ref": "../nodes/CT10.N11.schema.json"
