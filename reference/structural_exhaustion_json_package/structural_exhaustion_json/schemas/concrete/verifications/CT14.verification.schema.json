          "description": "Required discriminator for the complete verification of CT14 (Aggregate closure); must equal \"CT14\"."
        },
        "nodeRecords": {
          "type": "array",
          "prefixItems": [
            {
              "$ref": "../nodes/CT14.N01.schema.json"
            },
            {
              "$ref": "../nodes/CT14.N02.schema.json"
            },
            {
              "$ref": "../nodes/CT14.N03.schema.json"
            },
            {
              "$ref": "../nodes/CT14.N04.schema.json"
            },
            {
              "$ref": "../nodes/CT14.N05.schema.json"
            },
            {
              "$ref": "../nodes/CT14.N06.schema.json"
            },
            {
              "$ref": "../nodes/CT14.N07.schema.json"
            },
            {
              "$ref": "../nodes/CT14.N08.schema.json"
            },
            {
              "$ref": "../nodes/CT14.N09.schema.json"
            },
            {
              "$ref": "../nodes/CT14.N10.schema.json"
            },
            {
              "$ref": "../nodes/CT14.N11.schema.json"
            },
            {
              "$ref": "../nodes/CT14.N12.schema.json"
            },
            {
              "$ref": "../nodes/CT14.N13.schema.json"
