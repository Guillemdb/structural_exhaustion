          "description": "Required discriminator for the complete verification of CT4 (Charging schemes); must equal \"CT4\"."
        },
        "nodeRecords": {
          "type": "array",
          "prefixItems": [
            {
              "$ref": "../nodes/CT4.N01.schema.json"
            },
            {
              "$ref": "../nodes/CT4.N02.schema.json"
            },
            {
              "$ref": "../nodes/CT4.N03.schema.json"
            },
            {
              "$ref": "../nodes/CT4.N04.schema.json"
            },
            {
              "$ref": "../nodes/CT4.N05.schema.json"
            },
            {
              "$ref": "../nodes/CT4.N06.schema.json"
            },
            {
              "$ref": "../nodes/CT4.N07.schema.json"
            },
            {
              "$ref": "../nodes/CT4.N08.schema.json"
            },
            {
              "$ref": "../nodes/CT4.N09.schema.json"
            },
            {
              "$ref": "../nodes/CT4.N10.schema.json"
            },
            {
              "$ref": "../nodes/CT4.N11.schema.json"
            },
            {
              "$ref": "../nodes/CT4.N12.schema.json"
            },
            {
              "$ref": "../nodes/CT4.N13.schema.json"
            },
            {
              "$ref": "../nodes/CT4.N14.schema.json"
            },
            {
              "$ref": "../nodes/CT4.N15.schema.json"
            },
            {
              "$ref": "../nodes/CT4.N16.schema.json"
            },
            {
              "$ref": "../nodes/CT4.N17.schema.json"
            }
          ],
          "items": false,
          "minItems": 17,
          "maxItems": 17,
          "description": "Required complete verification sequence for CT4 (Charging schemes); must contain exactly 17 successful discharge records, one per node from CT4.N01 through CT4.N17 in source order, each satisfying its corresponding concrete node schema."
