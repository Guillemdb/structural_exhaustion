        },
        "nodeRecords": {
          "type": "array",
          "prefixItems": [
            {
              "$ref": "../nodes/CT5.N01.schema.json"
            },
            {
              "$ref": "../nodes/CT5.N02.schema.json"
            },
            {
              "$ref": "../nodes/CT5.N03.schema.json"
            },
            {
              "$ref": "../nodes/CT5.N04.schema.json"
            },
            {
              "$ref": "../nodes/CT5.N05.schema.json"
            },
            {
              "$ref": "../nodes/CT5.N06.schema.json"
            },
            {
              "$ref": "../nodes/CT5.N07.schema.json"
            },
            {
              "$ref": "../nodes/CT5.N08.schema.json"
            },
            {
              "$ref": "../nodes/CT5.N09.schema.json"
            },
            {
              "$ref": "../nodes/CT5.N10.schema.json"
            },
            {
              "$ref": "../nodes/CT5.N11.schema.json"
            },
            {
              "$ref": "../nodes/CT5.N12.schema.json"
            },
            {
              "$ref": "../nodes/CT5.N13.schema.json"
            },
            {
              "$ref": "../nodes/CT5.N14.schema.json"
            },
            {
              "$ref": "../nodes/CT5.N15.schema.json"
            },
            {
              "$ref": "../nodes/CT5.N16.schema.json"
            },
            {
              "$ref": "../nodes/CT5.N17.schema.json"
            },
            {
              "$ref": "../nodes/CT5.N18.schema.json"
            }
          ],
          "items": false,
          "minItems": 18,
          "maxItems": 18,
          "description": "Required complete verification sequence for CT5 (Local-to-global bookkeeping); must contain exactly 18 successful discharge records, one per node from CT5.N01 through CT5.N18 in source order, each satisfying its corresponding concrete node schema."
        }
      },
      "required": [
        "tacticId",
        "nodeRecords"
      ]
    }
  ]
