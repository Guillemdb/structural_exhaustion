syntax (name := ct2Discover)
  "ct2_discover " term " at " term : term
macro_rules
  | `(ct2_discover $capability:term at $ctx:term) =>
      `(StructuralExhaustion.CT2.Capability.discover $capability $ctx)

syntax (name := ct2Execute)
  "ct2_execute " term " at " term " on " term : term
macro_rules
  | `(ct2_execute $capability:term at $ctx:term on $input:term) =>
      `(StructuralExhaustion.CT2.run $capability $ctx $input)

syntax (name := ct2Tactic)
  "ct2 " term " at " term " on " term : tactic
macro_rules
  | `(tactic| ct2 $capability:term at $ctx:term on $input:term) =>
      `(tactic| exact StructuralExhaustion.CT2.run_verified
        $capability $ctx $input)

syntax (name := ct2TotalTactic)
  "ct2_total " term " at " term " on " term : tactic
macro_rules
  | `(tactic| ct2_total $capability:term at $ctx:term on $input:term) =>
      `(tactic| exact StructuralExhaustion.CT2.run_total
        $capability $ctx $input)

end StructuralExhaustion.CT2
