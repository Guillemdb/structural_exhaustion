/-- Router-visible CT2 residuals.  Neither residual contains a destination
input or a downstream tactic choice. -/
def residualKindContracts : List Core.ResidualKindContract := [
  {
    residualKindId := "CT2.residual.separatingContext"
    leanType := "StructuralExhaustion.CT2.SeparatingContextResidual"
    semanticFields := [
      ⟨"deletionCritical", "DeletionCriticalState", .derivedByComputation⟩,
      ⟨"candidate", "Candidate sourcePiece", .derivedByGenericSearch⟩,
      ⟨"separator", "ContextSeparator candidate", .derivedByGenericSearch⟩,
      ⟨"replacementTable", "ReplacementTable", .derivedByGenericTheorem⟩
    ]
    inheritedContext := .minimalCounterexampleBranch
  },
  {
    residualKindId := "CT2.residual.criticality"
    leanType := "StructuralExhaustion.CT2.CriticalityResidual"
    semanticFields := [
      ⟨"deletionCritical", "DeletionCriticalState", .derivedByComputation⟩,
      ⟨"replacementTable", "ReplacementTable", .derivedByGenericTheorem⟩,
      ⟨"noCandidate", "∀ candidate, False", .derivedByGenericTheorem⟩
    ]
    inheritedContext := .minimalCounterexampleBranch
  }
]

def residualKindIds : List String :=
  residualKindContracts.map (·.residualKindId)

